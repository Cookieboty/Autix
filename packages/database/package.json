  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^7.7.0",
    "typescript": "^5.7.0"
  }
}
