{
  "name": "@autix/database",
  "version": "0.0.0",
  "private": true,
  "exports": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun ../../node_modules/prisma/build/index.js generate --schema prisma/schema.prisma && tsc",
    "typecheck": "tsc --noEmit",
    "db:format": "bun ../../node_modules/prisma/build/index.js format --schema prisma/schema.prisma",
    "db:validate": "bun ../../node_modules/prisma/build/index.js validate --schema prisma/schema.prisma",
    "db:generate": "bun ../../node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "db:migrate": "bun ../../node_modules/prisma/build/index.js migrate dev --schema prisma/schema.prisma",
    "db:deploy": "bun ../../node_modules/prisma/build/index.js migrate deploy --schema prisma/schema.prisma",
    "db:push": "bun ../../node_modules/prisma/build/index.js db push --schema prisma/schema.prisma",
    "db:flat-migrate": "bun run scripts/flat-migrate.ts",
    "db:prepare-cutover": "bun run db:deploy && bun run db:flat-migrate && bun run db:seed:prod",
    "db:seed": "bun run build && bun run prisma/seed.ts",
    "db:seed:prod": "bun run prisma/seed-prod.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^7.7.0",
    "typescript": "^5.7.0"
  }
}
