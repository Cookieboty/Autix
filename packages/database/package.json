{
  "name": "@autix/database",
  "version": "0.0.0",
  "private": true,
  "exports": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bunx prisma generate --schema prisma/schema.prisma && tsc",
    "typecheck": "tsc --noEmit",
    "db:format": "bunx prisma format --schema prisma/schema.prisma",
    "db:validate": "bunx prisma validate --schema prisma/schema.prisma",
    "db:generate": "bunx prisma generate --schema prisma/schema.prisma",
    "db:migrate": "bunx prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "bunx prisma migrate deploy --schema prisma/schema.prisma",
    "db:push": "bunx prisma db push --schema prisma/schema.prisma",
    "db:flat-migrate": "bun run scripts/flat-migrate.ts",
    "db:prepare-cutover": "bun run db:flat-migrate && bun run db:deploy && bun run db:seed:prod",
    "db:seed": "bun run build && bun run prisma/seed.ts",
    "db:seed:prod": "bun run prisma/seed-prod.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "prisma": "^7.7.0",
    "typescript": "^5.7.0"
  }
}
