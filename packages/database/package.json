{
  "name": "@autix/database",
  "version": "0.0.0",
  "private": true,
  "exports": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "dotenv -e ../../.env -- prisma generate --schema prisma/schema.prisma && tsc",
    "test": "pnpm run build && vitest run",
    "typecheck": "tsc --noEmit",
    "db:format": "dotenv -e ../../.env -- prisma format --schema prisma/schema.prisma",
    "db:validate": "dotenv -e ../../.env -- prisma validate --schema prisma/schema.prisma",
    "db:generate": "dotenv -e ../../.env -- prisma generate --schema prisma/schema.prisma",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema prisma/schema.prisma",
    "db:push": "dotenv -e ../../.env -- prisma db push --schema prisma/schema.prisma",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --schema prisma/schema.prisma",
    "db:baseline:check": "dotenv -e ../../.env -- tsx scripts/check-migration-readiness.ts",
    "db:flat-migrate": "tsx scripts/flat-migrate.ts",
    "db:init-membership": "tsx scripts/init-membership-data.ts",
    "db:migrate-legacy": "tsx scripts/migrate-legacy-data.ts",
    "db:backfill-metrics": "dotenv -e ../../.env -- tsx scripts/backfill-resource-metrics.ts",
    "db:reconcile": "dotenv -e ../../.env -- prisma db push --schema prisma/schema.prisma",
    "db:prepare-cutover": "pnpm run db:flat-migrate && pnpm run db:deploy && pnpm run db:reconcile && pnpm run db:seed:prod && pnpm run db:init-membership && pnpm run db:seed:pricing",
    "db:seed:pricing": "pnpm --filter @autix/api run seed:pricing",
    "db:seed": "pnpm run build && dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:seed:prod": "tsx prisma/seed-prod.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
