{
  "name": "@autix/database",
  "version": "0.0.0",
  "private": true,
  "exports": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc",
    "typecheck": "tsc --noEmit",
