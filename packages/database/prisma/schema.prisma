enum PointGrantType {
  SUBSCRIPTION
  PURCHASED
  GIFT
  COMPENSATION
}

enum PointLedgerEventType {
  subscription_grant
  points_purchase
  generation_freeze
  generation_cost
  generation_refund
  admin_adjustment
  campaign_bonus
  expiration
  migration_legacy_balance
}

enum PointHoldStatus {
  PENDING
  PROCESSING
  CONFIRMED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
  BLOCKED
  EXPIRED
}

enum CampaignType {
  CONTINUOUS_USE
  INVITATION
  FEEDBACK
  REGISTRATION
  QUEST
  CUSTOM
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

model point_grants {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation("PointGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  grantType       PointGrantType
  sourceEvent     PointLedgerEventType
  sourceId        String?
  totalAmount     Int
  availableAmount Int                  @default(0)
  frozenAmount    Int                  @default(0)
  consumedAmount  Int                  @default(0)
  expiredAmount   Int                  @default(0)
  refundedAmount  Int                  @default(0)
  expiresAt       DateTime?
  usageScope      Json?
  metadata        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  holdItems       point_hold_items[]

  @@unique([userId, sourceEvent, sourceId])
  @@index([userId, expiresAt])
  @@index([userId, grantType])
  @@index([sourceEvent, sourceId])
}

model point_holds {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation("PointHoldUser", fields: [userId], references: [id], onDelete: Cascade)
  taskType             String
  taskId               String?
  estimatedAmount      Int
  confirmedAmount      Int?
  status               PointHoldStatus    @default(PENDING)
  pricingSnapshot      Json?
  refundPolicySnapshot Json?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  confirmedAt          DateTime?
  refundedAt           DateTime?
  items                point_hold_items[]

  @@index([userId, status])
  @@index([taskType, taskId])
}

model point_hold_items {
  id        String         @id @default(cuid())
  holdId    String
  hold      point_holds    @relation(fields: [holdId], references: [id], onDelete: Cascade)
  grantId   String
  grant     point_grants   @relation(fields: [grantId], references: [id], onDelete: Restrict)
  amount    Int
  grantType PointGrantType
  expiresAt DateTime?
  createdAt DateTime       @default(now())

  @@index([holdId])
  @@index([grantId])
}

model campaigns {
  id                     String               @id @default(cuid())
  code                   String               @unique
  name                   String
  description            String?
  type                   CampaignType
  status                 CampaignStatus       @default(DRAFT)
  startsAt               DateTime?
  endsAt                 DateTime?
  dailyBudget            Int?
  totalBudget            Int?
  usedBudget             Int                  @default(0)
  perUserDailyCap        Int?
  perUserTotalCap        Int?
  rewardGrantType        PointGrantType       @default(GIFT)
  rewardSourceEvent      PointLedgerEventType @default(campaign_bonus)
  rewardPointsExpression Json?
  rewardExpiresInDays    Int                  @default(7)
  rewardUsageScope       Json?
  eligibility            Json?
  metadata               Json?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  rewards                campaign_rewards[]

  @@index([status, startsAt, endsAt])
  @@index([type, status])
}

model campaign_rewards {
