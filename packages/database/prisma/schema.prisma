generator client {
  provider        = "prisma-client"
  output          = "../src/generated/client"
  moduleFormat    = "cjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
  PENDING
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  EXPORT
  IMPORT
}

enum PermissionType {
  FRONTEND // 前端权限：控制按钮、组件显示
  BACKEND // 后端权限：控制API访问
}

enum SystemStatus {
  ACTIVE
  DISABLED
}

enum ClientStatus {
  ACTIVE
  DISABLED
}

enum RegistrationStatus {
  PENDING_ACTIVATION
  PENDING
  APPROVED
  REJECTED
}

model System {
  id            String               @id @default(cuid())
  name          String
  code          String               @unique
  description   String?
  status        SystemStatus         @default(ACTIVE)
  sort          Int                  @default(0)
  autoApprove   Boolean              @default(false)
  menus         Menu[]
  roles         Role[]
  clients       OAuthClient[]
  registrations SystemRegistration[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("systems")
}

model User {
  id                             String                       @id @default(cuid())
  username                       String                       @unique
  email                          String                       @unique
  emailVerified                  Boolean                      @default(true)
  pendingEmail                   String?
  password                       String?
  realName                       String?
  avatar                         String?
  phone                          String?
  language                       String?                      @default("zh-CN")
  status                         UserStatus                   @default(ACTIVE)
  isSuperAdmin                   Boolean                      @default(false)
  roles                          UserRole[]
  sessions                       UserSession[]
  accounts                       UserAccount[]
  registrations                  SystemRegistration[]         @relation("UserRegistrations")
  processedRegs                  SystemRegistration[]         @relation("ProcessedRegistrations")
  artifacts                      artifacts[]                  @relation("ArtifactUser")
  conversations                  conversations[]              @relation("ConversationUser")
  documents                      documents[]                  @relation("DocumentUser")
  taskEvents                     task_events[]                @relation("TaskEventUser")
  arenaSessions                  arena_sessions[]             @relation("ArenaSessionUser")
  imageTemplates                 image_templates[]            @relation("ImageTemplateAuthor")
  videoTemplates                 video_templates[]            @relation("VideoTemplateAuthor")
  imageTemplatesCreated          image_templates[]            @relation("ImageTemplateCreatedBy")
  imageTemplatesReviewed         image_templates[]            @relation("ImageTemplateReviewer")
  videoTemplatesCreated          video_templates[]            @relation("VideoTemplateCreatedBy")
  videoTemplatesReviewed         video_templates[]            @relation("VideoTemplateReviewer")
  skills                         skills[]                     @relation("SkillAuthor")
  mcpServers                     mcp_servers[]                @relation("McpServerAuthor")
  agents                         agents[]                     @relation("AgentAuthor")
  imageGenerations               image_generations[]          @relation("ImageGenerationUser")
  videoGenerations               video_generations[]          @relation("VideoGenerationUser")
  resourceAcquisitions           user_resource_acquisitions[] @relation("ResourceAcquisitionUser")
  resourceLikes                  resource_likes[]             @relation("ResourceLikeUser")
  resourceFavorites              resource_favorites[]         @relation("ResourceFavoriteUser")
  resourceViews                  resource_views[]             @relation("ResourceViewUser")
  activatedConversationResources conversation_resources[]     @relation("ConversationResourceActivator")
  memberships                    user_memberships[]           @relation("MembershipUser")
  points                         user_points[]                @relation("UserPointsUser")
  pointsRecords                  points_records[]             @relation("PointsRecordUser")
  pointGrants                    point_grants[]               @relation("PointGrantUser")
  pointHolds                     point_holds[]                @relation("PointHoldUser")
  campaignRewards                campaign_rewards[]           @relation("CampaignRewardUser")
  activityStreaks                user_activity_streaks[]      @relation("ActivityStreakUser")
  orders                         orders[]                     @relation("OrderUser")
  paymentEvents                  payment_events[]             @relation("PaymentEventOrderUser")
  inviteCodes                    invite_codes[]               @relation("InviteCodeUser")
  sentInvites                    invite_records[]             @relation("InviteRecordInviter")
  receivedInvites                invite_records[]             @relation("InviteRecordInvitee")
  videoProjects                  video_projects[]             @relation("VideoProjectUser")
  videoProjectShares             video_project_shares[]
  videoClipGenerations           video_clip_generations[]     @relation("VideoClipGenerationUser")
  videoWorkflowTemplates         video_workflow_templates[]   @relation("VideoWorkflowTemplateAuthor")
  materialAssets                 material_assets[]            @relation("MaterialAssetUser")
  materialFolders                material_folders[]           @relation("MaterialFolderUser")
  canvasBoards                   canvas_boards[]              @relation("CanvasBoardUser")
  galleryPosts                   gallery_posts[]              @relation("GalleryPostAuthor")
  createdAt                      DateTime                     @default(now())
  updatedAt                      DateTime                     @updatedAt
  lastLoginAt                    DateTime?
  signupIp                       String?
  signupDeviceId                 String?
  riskProfile                    user_risk_profiles?          @relation("UserRiskProfile")
  riskEvents                     user_risk_events[]           @relation("UserRiskEvent")

  @@map("users")
}

/// 风控安全等级：L0 正常 / L1 关注 / L2 受限 / L3 封禁
enum RiskLevel {
  L0
  L1
  L2
  L3
}

/// 用户风控档案（每用户一条）
model user_risk_profiles {
  userId         String    @id
  user           User      @relation("UserRiskProfile", fields: [userId], references: [id], onDelete: Cascade)
  level          RiskLevel @default(L0)
  score          Int       @default(0)
  manualOverride Boolean   @default(false)
  topSignals     Json?
  evaluatedAt    DateTime?
  blockedAt      DateTime?
  blockedReason  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([level, score])
}

/// 风控信号 / 处置流水（追加式，用于时间线 + 审计）
model user_risk_events {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserRiskEvent", fields: [userId], references: [id], onDelete: Cascade)
  type      String
  severity  Int      @default(0)
  detail    Json?
  actorId   String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Role {
  id          String           @id @default(cuid())
  systemId    String
  system      System           @relation(fields: [systemId], references: [id], onDelete: Cascade)
  name        String
  code        String
  description String?
  sort        Int              @default(0)
  users       UserRole[]
  permissions RolePermission[]
  menus       RoleMenu[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([systemId, code])
  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id          String           @id @default(cuid())
  menuId      String
  menu        Menu             @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name        String
  code        String           @unique
  type        PermissionType
  action      PermissionAction
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Menu {
  id          String       @id @default(cuid())
  systemId    String
  system      System       @relation(fields: [systemId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Menu?        @relation("MenuTree", fields: [parentId], references: [id])
  children    Menu[]       @relation("MenuTree")
  name        String
  nameEn      String?
  nameZhTW    String?      @map("name_zh_tw")
  nameFr      String?      @map("name_fr")
  nameJa      String?      @map("name_ja")
  nameRu      String?      @map("name_ru")
  nameVi      String?      @map("name_vi")
  code        String
  path        String?
  icon        String?
  sort        Int          @default(0)
  visible     Boolean      @default(true)
  permissions Permission[]
  roles       RoleMenu[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([systemId, code])
  @@map("menus")
}

model RoleMenu {
  id        String   @id @default(cuid())
  roleId    String
  menuId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([roleId, menuId])
  @@map("role_menus")
}

model UserSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken    String   @unique
  accessToken     String?
  clientId        String?
  scopes          String[] @default([])
  currentSystemId String?
  expiresAt       DateTime
  isActive        Boolean  @default(true)
  ip              String?
  userAgent       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([refreshToken])
  @@map("user_sessions")
}

model UserAccount {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  accessToken       String?   @db.Text
  refreshToken      String?   @db.Text
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  idToken           String?   @db.Text
  sessionState      String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("user_accounts")
}

/// 三方登录：CSRF state + PKCE verifier + 发起上下文（非"本系统作 OAuth 服务器"，勿与 OAuthClient 混淆）
model SocialLoginState {
  id           String   @id @default(cuid())
  state        String   @unique
  nonce        String?
  codeVerifier String?
  provider     String
  systemCode   String
  clientType   String
  redirectUri  String
  inviteCode   String?
  deviceId     String?
  linkUserId   String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
  @@map("social_login_states")
}

/// 三方登录：回调成功后签发的一次性 login code，凭它换真正 tokenPair（token 不经 URL）
model SocialLoginCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  sessionId String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("social_login_codes")
}

model OAuthClient {
  id           String       @id @default(cuid())
  clientId     String       @unique
  clientSecret String
  name         String
  description  String?
  redirectUris String[]
  grantTypes   String[]
  scopes       String[]
  systemId     String?
  system       System?      @relation(fields: [systemId], references: [id])
  status       ClientStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("oauth_clients")
}

model OAuthAuthorizationCode {
  id          String   @id @default(cuid())
  code        String   @unique
  clientId    String
  userId      String
  redirectUri String
  scopes      String[]
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([code])
  @@index([clientId])
  @@map("oauth_authorization_codes")
}

model SystemRegistration {
  id            String             @id @default(cuid())
  userId        String
  systemId      String
  status        RegistrationStatus @default(PENDING)
  note          String?
  inviteCode    String?
  createdAt     DateTime           @default(now())
  processedAt   DateTime?
  processedById String?

  user        User   @relation("UserRegistrations", fields: [userId], references: [id], onDelete: Cascade)
  system      System @relation(fields: [systemId], references: [id])
  processedBy User?  @relation("ProcessedRegistrations", fields: [processedById], references: [id])

  @@unique([userId, systemId])
  @@map("system_registrations")
}

// Chat service schema merged for monolith flat migration.
model artifact_versions {
  id              String    @id @default(cuid())
  artifactId      String
  version         Int
  content         String
  changelog       String?
  sourcetags      String[]
  sourceMessageId String?
  createdAt       DateTime  @default(now())
  artifacts       artifacts @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  messages        messages? @relation(fields: [sourceMessageId], references: [id])

  @@unique([artifactId, version])
  @@index([artifactId, createdAt])
  @@index([artifactId, sourcetags])
}

model artifacts {
  id                  String              @id @default(cuid())
  conversationId      String              @unique
  userId              String
  title               String
  type                ArtifactType        @default(MARKDOWN)
  language            String?
  content             String
  currentVersion      Int                 @default(1)
  sourceWorkflowRunId String?
  sourceStepKey       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  artifact_versions   artifact_versions[]
  conversations       conversations       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user                User                @relation("ArtifactUser", fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
}

model conversations {
  id           String                   @id @default(cuid())
  userId       String
  title        String                   @default("New Conversation")
  kind         AgentKind                @default(chat)
  agentId      String?
  agent        agents?                  @relation("ConversationAgent", fields: [agentId], references: [id])
  user         User                     @relation("ConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  artifacts    artifacts?
  messages     messages[]
  resources    conversation_resources[]
  agentRuns    agent_runs[]
  videoProject video_projects?

  @@index([userId])
  @@index([userId, kind])
  @@index([userId, updatedAt])
}

model document_chunks {
  id         String                 @id @default(cuid())
  documentId String
  content    String
  embedding  Unsupported("vector")?
  chunkIndex Int
  documents  documents              @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model documents {
  id              String            @id @default(cuid())
  userId          String
  filename        String
  mimeType        String
  createdAt       DateTime          @default(now())
  filePath        String?
  size            Int
  storageBucket   String?
  storageKey      String?
  storageRegion   String?
  storageType     String            @default("local")
  storageUrl      String?
  chunkCount      Int               @default(0)
  status          String            @default("pending")
  document_chunks document_chunks[]
  user            User              @relation("DocumentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model messages {
  id                String              @id @default(cuid())
  conversationId    String
  role              MessageRole
  content           String
  createdAt         DateTime            @default(now())
  metadata          Json?
  artifact_versions artifact_versions[]
  conversations     conversations       @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model model_configs {
  id                      String                           @id @default(cuid())
  name                    String                           @db.VarChar(100)
  provider                String                           @default("openai") @db.VarChar(50)
  model                   String                           @db.VarChar(100)
  type                    ModelType                        @default(general)
  priority                Int                              @default(0)
  baseUrl                 String?                          @db.VarChar(200)
  apiKey                  String?                          @db.VarChar(200)
  metadata                Json?
  isActive                Boolean                          @default(true)
  isDefault               Boolean                          @default(false)
  visibility              ModelVisibility                  @default(public)
  createdBy               String?                          @db.VarChar(50)
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt
  capabilities            String[]                         @default(["text"])
  /// NULL = 尚未配置（不可与占位空 schema 混淆，例如空 terms 会被 evaluatePricing 计算为 0）
  paramsSchema            Json?
  pricingSchema           Json?
  schemaVersion           Int                              @default(1)
  description             Json                             @default("{}")
  allowedMembershipLevels model_config_membership_levels[]
  taskBindings            task_model_bindings[]

  @@index([createdBy])
  @@index([isActive])
  @@index([isDefault])
  @@index([type])
  @@index([visibility])
}

model model_config_membership_levels {
  modelConfigId String
  levelId       String
  createdAt     DateTime          @default(now())
  level         membership_levels @relation(fields: [levelId], references: [id], onDelete: Cascade)
  modelConfig   model_configs     @relation(fields: [modelConfigId], references: [id], onDelete: Cascade)

  @@id([modelConfigId, levelId])
  @@index([levelId])
}

model task_definitions {
  id              String                @id @default(cuid())
  taskType        String                @unique @db.VarChar(64)
  name            String                @db.VarChar(100)
  category        String                @db.VarChar(20)
  fixedCostSchema Json?
  isActive        Boolean               @default(true)
  sort            Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  bindings        task_model_bindings[]

  @@index([isActive])
  @@map("task_definitions")
}

model task_model_bindings {
  taskType      String           @db.VarChar(64)
  modelConfigId String
  multiplier    Decimal          @default(1.0) @db.Decimal(6, 3)
  isDefault     Boolean          @default(false)
  isActive      Boolean          @default(true)
  sort          Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  task          task_definitions @relation(fields: [taskType], references: [taskType], onDelete: Cascade)
  modelConfig   model_configs    @relation(fields: [modelConfigId], references: [id], onDelete: Cascade)

  @@id([taskType, modelConfigId])
  @@index([modelConfigId])
  @@index([taskType, isActive])
  @@map("task_model_bindings")
}

model pricing_discounts {
  id            String    @id @default(cuid())
  code          String    @unique @db.VarChar(64)
  name          String    @db.VarChar(100)
  factor        Decimal   @db.Decimal(6, 3)
  scope         Json      @default("{}")
  stackable     Boolean   @default(false)
  priority      Int       @default(0)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive, effectiveFrom, effectiveTo])
  @@map("pricing_discounts")
}

model system_settings {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(120)
  value     String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("system_settings")
}

model task_events {
  id        String     @id @default(cuid())
  userId    String     @db.VarChar(255)
  taskType  String     @db.VarChar(100)
  taskId    String     @db.VarChar(255)
  status    TaskStatus
  message   String?
  metadata  Json?
  user      User       @relation("TaskEventUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  readAt    DateTime?  @db.Timestamptz(6)

  @@index([taskType])
  @@index([userId, createdAt])
}

model batch_jobs {
  id           String       @id @default(uuid())
  userId       String
  type         BatchJobType
  resourceType ResourceType
  status       TaskStatus   @default(pending)
  total        Int          @default(0)
  processed    Int          @default(0)
  failed       Int          @default(0)
  errorLog     Json?
  metadata     Json?
  createdAt    DateTime     @default(now())
  completedAt  DateTime?

  @@index([userId, createdAt])
  @@index([status])
}

enum ArtifactType {
  MARKDOWN
  CODE
  DOCUMENT
  TABLE
  CHART
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ModelType {
  general
  code
  intent
  embedding
  video
}

enum ModelVisibility {
  public
  private
}

enum TaskStatus {
  pending
  processing
  done
  error
}

enum BatchJobType {
  IMPORT
  APPROVE
  REJECT
  REVISE
  DELETE
}

model arena_sessions {
  id               String        @id @default(cuid())
  userId           String
  title            String        @default("新对比")
  selectedModelIds String[]      @default([])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation("ArenaSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  turns            arena_turns[]

  @@index([userId])
}

model arena_turns {
  id          String            @id @default(cuid())
  sessionId   String
  session     arena_sessions    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userMessage String
  images      String[]          @default([])
  createdAt   DateTime          @default(now())
  responses   arena_responses[]

  @@index([sessionId])
}

model arena_responses {
  id               String      @id @default(cuid())
  turnId           String
  turn             arena_turns @relation(fields: [turnId], references: [id], onDelete: Cascade)
  modelConfigId    String
  content          String      @default("")
  images           String[]    @default([])
  durationMs       Int?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  status           String      @default("pending")
  error            String?
  createdAt        DateTime    @default(now())

  @@index([turnId])
}

// ── Multi-Resource Marketplace ──────────────────────────────────────────────

enum ResourceType {
  SKILL
  MCP
  AGENT
  IMAGE_TEMPLATE
  VIDEO_TEMPLATE
  GALLERY_POST
}

enum RuntimeReq {
  CLOUD
  DESKTOP_ONLY
  EITHER
}

enum DetectionSrc {
  AUTO
  AUTHOR
  ADMIN
}

enum TemplateStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum ImageTemplateSource {
  ADMIN_CREATED
  GALLERY_CONVERSION
  SYSTEM
}

enum VideoTemplateSource {
  ADMIN_CREATED
  SYSTEM
}

enum McpTransport {
  stdio
  sse
  http
}

/// Plan C Task 10：favoriteCount 已删（收藏改走 FavoriteLibraryService + resource_metrics 单一来源，
/// 列表/详情展示改读 resource_metrics.favoriteCount）。likeCount/useCount 暂保留——它们仍是
/// base-resource.service.like() 与 template-generation.repository 生成计数、以及
/// marketplace-query.repository 首页/热门/编辑精选排序的直接读写列，全量迁到 resource_metrics
/// 需要同时重做这三处排序/写入路径，超出本任务范围，留作后续任务。
model image_templates {
  id            String   @id @default(cuid())
  title         String   @db.VarChar(200)
  description   String?
  category      String   @db.VarChar(50)
  prompt        String
  variables     Json
  coverImage    String?
  exampleImages String[] @default([])
  modelHint     String?  @db.VarChar(100)
  tags          String[] @default([])
  version       Int      @default(1)

  pointsCost Int @default(0)

  runtimeRequirement RuntimeReq   @default(CLOUD)
  runtimeDetectedBy  DetectionSrc @default(AUTO)
  runtimeReason      String?

  status       TemplateStatus @default(PENDING)
  rejectReason String?

  authorId      String
  useCount      Int     @default(0)
  likeCount     Int     @default(0)
  isHot         Boolean @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  sourceType          ImageTemplateSource @default(ADMIN_CREATED)
  sourceGalleryPostId String?             @unique
  sourceGalleryPost   gallery_posts?      @relation("ImageTemplateSourceGallery", fields: [sourceGalleryPostId], references: [id], onDelete: Restrict)
  createdById         String
  createdBy           User                @relation("ImageTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  reviewedById        String?
  reviewedAt          DateTime?
