  frozenBalance       Int      @default(0)
  totalBalance        Int      @default(0)
  subscriptionBalance Int      @default(0)
  purchasedBalance    Int      @default(0)
  giftBalance         Int      @default(0)
  compensationBalance Int      @default(0)
  updatedAt           DateTime @updatedAt
}

model points_records {
  id        String             @id @default(cuid())
