  triggerEventId String?
  pointsGranted  Int
  pointGrantId   String?
  grantedAt      DateTime  @default(now())
  metadata       Json?

  @@unique([campaignId, triggerKey])
  @@index([userId, grantedAt])
  @@index([campaignId, grantedAt])
}

model user_activity_streaks {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("ActivityStreakUser", fields: [userId], references: [id], onDelete: Cascade)
  streakType      String
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActiveDate  DateTime?
