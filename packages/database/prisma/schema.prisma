  inviteeUserId String
  rewardPoints  Int      @default(0)
  rewarded      Boolean  @default(false)
  createdAt     DateTime @default(now())

  inviteCode invite_codes @relation(fields: [inviteCodeId], references: [id])
  inviter    User         @relation("InviteRecordInviter", fields: [inviterUserId], references: [id], onDelete: Restrict)
  invitee    User         @relation("InviteRecordInvitee", fields: [inviteeUserId], references: [id], onDelete: Restrict)

  @@unique([inviteeUserId])
  @@index([inviterUserId])
