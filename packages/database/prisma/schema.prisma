  updatedAt             DateTime @updatedAt

  @@index([isActive, sort])
}

model user_points {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation("UserPointsUser", fields: [userId], references: [id], onDelete: Cascade)
