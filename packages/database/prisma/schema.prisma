generator client {
  provider        = "prisma-client"
  output          = "../src/generated/client"
  moduleFormat    = "cjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
  PENDING
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  EXPORT
  IMPORT
}

enum PermissionType {
  FRONTEND // 前端权限：控制按钮、组件显示
  BACKEND // 后端权限：控制API访问
}

enum SystemStatus {
  ACTIVE
  DISABLED
}

enum ClientStatus {
  ACTIVE
  DISABLED
}

enum RegistrationStatus {
  PENDING_ACTIVATION
  PENDING
  APPROVED
  REJECTED
}

model System {
  id            String               @id @default(cuid())
  name          String
  code          String               @unique
  description   String?
  status        SystemStatus         @default(ACTIVE)
  sort          Int                  @default(0)
  autoApprove   Boolean              @default(false)
  menus         Menu[]
  roles         Role[]
  clients       OAuthClient[]
  registrations SystemRegistration[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("systems")
}

model User {
  id                             String                       @id @default(cuid())
  username                       String                       @unique
  email                          String                       @unique
  password                       String?
  realName                       String?
  avatar                         String?
  phone                          String?
  language                       String?                      @default("zh-CN")
  status                         UserStatus                   @default(ACTIVE)
  isSuperAdmin                   Boolean                      @default(false)
  roles                          UserRole[]
  sessions                       UserSession[]
  accounts                       UserAccount[]
  registrations                  SystemRegistration[]         @relation("UserRegistrations")
  processedRegs                  SystemRegistration[]         @relation("ProcessedRegistrations")
  artifacts                      artifacts[]                  @relation("ArtifactUser")
  conversations                  conversations[]              @relation("ConversationUser")
  documents                      documents[]                  @relation("DocumentUser")
  taskEvents                     task_events[]                @relation("TaskEventUser")
  arenaSessions                  arena_sessions[]             @relation("ArenaSessionUser")
  imageTemplates                 image_templates[]            @relation("ImageTemplateAuthor")
  videoTemplates                 video_templates[]            @relation("VideoTemplateAuthor")
  skills                         skills[]                     @relation("SkillAuthor")
  mcpServers                     mcp_servers[]                @relation("McpServerAuthor")
  agents                         agents[]                     @relation("AgentAuthor")
  imageGenerations               image_generations[]          @relation("ImageGenerationUser")
  videoGenerations               video_generations[]          @relation("VideoGenerationUser")
  resourceAcquisitions           user_resource_acquisitions[] @relation("ResourceAcquisitionUser")
  resourceFavorites              resource_favorites[]         @relation("ResourceFavoriteUser")
  resourceViews                  resource_views[]             @relation("ResourceViewUser")
  activatedConversationResources conversation_resources[]     @relation("ConversationResourceActivator")
  memberships                    user_memberships[]           @relation("MembershipUser")
  points                         user_points[]                @relation("UserPointsUser")
  pointsRecords                  points_records[]             @relation("PointsRecordUser")
  orders                         orders[]                     @relation("OrderUser")
  inviteCodes                    invite_codes[]               @relation("InviteCodeUser")
  sentInvites                    invite_records[]             @relation("InviteRecordInviter")
  receivedInvites                invite_records[]             @relation("InviteRecordInvitee")
  amuxCredential                 amux_credentials?            @relation("AmuxCredentialUser")
  videoProjects                  video_projects[]             @relation("VideoProjectUser")
  videoClipGenerations           video_clip_generations[]     @relation("VideoClipGenerationUser")
  videoWorkflowTemplates         video_workflow_templates[]   @relation("VideoWorkflowTemplateAuthor")
  createdAt                      DateTime                     @default(now())
  updatedAt                      DateTime                     @updatedAt
  lastLoginAt                    DateTime?

  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  systemId    String
  system      System           @relation(fields: [systemId], references: [id], onDelete: Cascade)
  name        String
  code        String
  description String?
  sort        Int              @default(0)
  users       UserRole[]
  permissions RolePermission[]
  menus       RoleMenu[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([systemId, code])
  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id          String           @id @default(cuid())
  menuId      String
  menu        Menu             @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name        String
  code        String           @unique
  type        PermissionType
  action      PermissionAction
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Menu {
  id          String       @id @default(cuid())
  systemId    String
  system      System       @relation(fields: [systemId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Menu?        @relation("MenuTree", fields: [parentId], references: [id])
  children    Menu[]       @relation("MenuTree")
  name        String
  nameEn      String?
  nameZhTW    String?      @map("name_zh_tw")
  nameFr      String?      @map("name_fr")
  nameJa      String?      @map("name_ja")
  nameRu      String?      @map("name_ru")
  nameVi      String?      @map("name_vi")
  code        String
  path        String?
  icon        String?
  sort        Int          @default(0)
  visible     Boolean      @default(true)
  permissions Permission[]
  roles       RoleMenu[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([systemId, code])
  @@map("menus")
}

model RoleMenu {
  id        String   @id @default(cuid())
  roleId    String
  menuId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([roleId, menuId])
  @@map("role_menus")
}

model UserSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken    String   @unique
  accessToken     String?
  clientId        String?
  scopes          String[] @default([])
  currentSystemId String?
  expiresAt       DateTime
  isActive        Boolean  @default(true)
  ip              String?
  userAgent       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([refreshToken])
  @@map("user_sessions")
}

model UserAccount {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  accessToken       String?   @db.Text
  refreshToken      String?   @db.Text
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  idToken           String?   @db.Text
  sessionState      String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("user_accounts")
}

model OAuthClient {
  id           String       @id @default(cuid())
  clientId     String       @unique
  clientSecret String
  name         String
  description  String?
  redirectUris String[]
  grantTypes   String[]
  scopes       String[]
  systemId     String?
  system       System?      @relation(fields: [systemId], references: [id])
  status       ClientStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("oauth_clients")
}

model OAuthAuthorizationCode {
  id          String   @id @default(cuid())
  code        String   @unique
  clientId    String
  userId      String
  redirectUri String
  scopes      String[]
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([code])
  @@index([clientId])
  @@map("oauth_authorization_codes")
}

model SystemRegistration {
  id            String             @id @default(cuid())
  userId        String
  systemId      String
  status        RegistrationStatus @default(PENDING)
  note          String?
  inviteCode    String?
  createdAt     DateTime           @default(now())
  processedAt   DateTime?
  processedById String?

  user        User   @relation("UserRegistrations", fields: [userId], references: [id], onDelete: Cascade)
  system      System @relation(fields: [systemId], references: [id])
  processedBy User?  @relation("ProcessedRegistrations", fields: [processedById], references: [id])

  @@unique([userId, systemId])
  @@map("system_registrations")
}

// Chat service schema merged for monolith flat migration.
model artifact_versions {
  id              String    @id @default(cuid())
  artifactId      String
  version         Int
  content         String
  changelog       String?
  sourcetags      String[]
  sourceMessageId String?
  createdAt       DateTime  @default(now())
  artifacts       artifacts @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  messages        messages? @relation(fields: [sourceMessageId], references: [id])

  @@unique([artifactId, version])
  @@index([artifactId, createdAt])
  @@index([artifactId, sourcetags])
}

model artifacts {
  id                  String              @id @default(cuid())
  conversationId      String              @unique
  userId              String
  title               String
  type                ArtifactType        @default(MARKDOWN)
  language            String?
  content             String
  currentVersion      Int                 @default(1)
  sourceWorkflowRunId String?
  sourceStepKey       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  artifact_versions   artifact_versions[]
  conversations       conversations       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user                User                @relation("ArtifactUser", fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
}

model conversations {
  id           String                   @id @default(cuid())
  userId       String
  title        String                   @default("New Conversation")
  kind         AgentKind                @default(chat)
  agentId      String?
  agent        agents?                  @relation("ConversationAgent", fields: [agentId], references: [id])
  user         User                     @relation("ConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  artifacts    artifacts?
  messages     messages[]
  resources    conversation_resources[]
  agentRuns    agent_runs[]
  videoProject video_projects?

  @@index([userId])
  @@index([userId, kind])
  @@index([userId, updatedAt])
}

model document_chunks {
  id         String                 @id @default(cuid())
  documentId String
  content    String
  embedding  Unsupported("vector")?
  chunkIndex Int
  documents  documents              @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model documents {
  id              String            @id @default(cuid())
  userId          String
  filename        String
  mimeType        String
  createdAt       DateTime          @default(now())
  filePath        String?
  size            Int
  storageBucket   String?
  storageKey      String?
  storageRegion   String?
  storageType     String            @default("local")
  storageUrl      String?
  chunkCount      Int               @default(0)
  status          String            @default("pending")
  document_chunks document_chunks[]
  user            User              @relation("DocumentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model messages {
  id                String              @id @default(cuid())
  conversationId    String
  role              MessageRole
  content           String
  createdAt         DateTime            @default(now())
  metadata          Json?
  artifact_versions artifact_versions[]
  conversations     conversations       @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model model_configs {
  id              String          @id @default(cuid())
  name            String          @db.VarChar(100)
  provider        String          @default("openai") @db.VarChar(50)
  model           String          @db.VarChar(100)
  type            ModelType       @default(general)
  priority        Int             @default(0)
  baseUrl         String?         @db.VarChar(200)
  apiKey          String?         @db.VarChar(200)
  metadata        Json?
  isActive        Boolean         @default(true)
  isDefault       Boolean         @default(false)
  visibility      ModelVisibility @default(public)
  createdBy       String?         @db.VarChar(50)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  capabilities    String[]        @default(["text"])
  pointCostWeight Decimal         @default(1.0) @db.Decimal(6, 2)

  @@index([createdBy])
  @@index([isActive])
  @@index([isDefault])
  @@index([type])
  @@index([visibility])
}

model task_events {
  id        String     @id @default(cuid())
  userId    String     @db.VarChar(255)
  taskType  String     @db.VarChar(100)
  taskId    String     @db.VarChar(255)
  status    TaskStatus
  message   String?
  metadata  Json?
  user      User       @relation("TaskEventUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  readAt    DateTime?  @db.Timestamptz(6)

  @@index([taskType])
  @@index([userId, createdAt])
}

model batch_jobs {
  id           String       @id @default(uuid())
  userId       String
  type         BatchJobType
  resourceType ResourceType
  status       TaskStatus   @default(pending)
  total        Int          @default(0)
  processed    Int          @default(0)
  failed       Int          @default(0)
  errorLog     Json?
  metadata     Json?
  createdAt    DateTime     @default(now())
  completedAt  DateTime?

  @@index([userId, createdAt])
  @@index([status])
}

enum ArtifactType {
  MARKDOWN
  CODE
  DOCUMENT
  TABLE
  CHART
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ModelType {
  general
  code
  intent
  embedding
  video
}

enum ModelVisibility {
  public
  private
}

enum TaskStatus {
  pending
  processing
  done
  error
}

enum BatchJobType {
  IMPORT
  APPROVE
  REJECT
  REVISE
  DELETE
}

model arena_sessions {
  id               String        @id @default(cuid())
  userId           String
  title            String        @default("新对比")
  selectedModelIds String[]      @default([])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation("ArenaSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  turns            arena_turns[]

  @@index([userId])
}

model arena_turns {
  id          String            @id @default(cuid())
  sessionId   String
  session     arena_sessions    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userMessage String
  images      String[]          @default([])
  createdAt   DateTime          @default(now())
  responses   arena_responses[]

  @@index([sessionId])
}

model arena_responses {
  id               String      @id @default(cuid())
  turnId           String
  turn             arena_turns @relation(fields: [turnId], references: [id], onDelete: Cascade)
  modelConfigId    String
  content          String      @default("")
  images           String[]    @default([])
  durationMs       Int?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  status           String      @default("pending")
  error            String?
  createdAt        DateTime    @default(now())

  @@index([turnId])
}

// ── Multi-Resource Marketplace ──────────────────────────────────────────────

enum ResourceType {
  SKILL
  MCP
  AGENT
  IMAGE_TEMPLATE
  VIDEO_TEMPLATE
}

enum RuntimeReq {
  CLOUD
  DESKTOP_ONLY
  EITHER
}

enum DetectionSrc {
  AUTO
  AUTHOR
  ADMIN
}

enum TemplateStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum McpTransport {
  stdio
  sse
  http
}

model image_templates {
  id            String   @id @default(cuid())
  title         String   @db.VarChar(200)
  description   String?
  category      String   @db.VarChar(50)
  prompt        String
  variables     Json
  coverImage    String?
  exampleImages String[] @default([])
  modelHint     String?  @db.VarChar(100)
  tags          String[] @default([])
  version       Int      @default(1)

  pointsCost Int @default(0)

  runtimeRequirement RuntimeReq   @default(CLOUD)
  runtimeDetectedBy  DetectionSrc @default(AUTO)
  runtimeReason      String?

  status       TemplateStatus @default(PENDING)
  rejectReason String?

  authorId      String
  useCount      Int    @default(0)
  likeCount     Int    @default(0)
  favoriteCount Int    @default(0)

  originalUrl      String?
  authorName       String?  @db.VarChar(200)
  authorUrl        String?
  sourcePlatform   String?  @db.VarChar(100)
  externalId       String?  @db.VarChar(100)
  externalSlug     String?
  externalMetadata Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  generations image_generations[]
  author      User                @relation("ImageTemplateAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([useCount])
  @@index([publishedAt])
}

model video_templates {
  id           String   @id @default(cuid())
  title        String   @db.VarChar(200)
  description  String?
  category     String   @db.VarChar(50)
  prompt       String
  variables    Json
  coverImage   String?
  exampleMedia String[] @default([])
  modelHint    String?  @db.VarChar(100)
  durationSec  Int?
  tags         String[] @default([])
  version      Int      @default(1)

  defaultParams Json?
  materialSlots Json?

  pointsCost Int @default(0)

  runtimeRequirement RuntimeReq   @default(CLOUD)
  runtimeDetectedBy  DetectionSrc @default(AUTO)
  runtimeReason      String?

  status       TemplateStatus @default(PENDING)
  rejectReason String?

  authorId      String
  useCount      Int    @default(0)
  likeCount     Int    @default(0)
  favoriteCount Int    @default(0)

  originalUrl      String?
  authorName       String?  @db.VarChar(200)
  authorUrl        String?
  sourcePlatform   String?  @db.VarChar(100)
  externalId       String?  @db.VarChar(100)
  externalSlug     String?
  externalMetadata Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  generations video_generations[]
  author      User                @relation("VideoTemplateAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([useCount])
  @@index([publishedAt])
}

model skills {
  id                String   @id @default(cuid())
  title             String   @db.VarChar(200)
  description       String?
  category          String   @db.VarChar(50)
  rawMarkdown       String?  @db.Text
  sourceFormat      String   @default("skill_md") @db.VarChar(50)
  parsedFrontmatter Json?
  instructions      String   @db.Text
  frontmatter       Json
  variables         Json
  coverImage        String?
  exampleMedia      String[] @default([])
  modelHint         String?  @db.VarChar(100)
  tags              String[] @default([])
  version           Int      @default(1)

  pointsCost Int @default(0)

  runtimeRequirement RuntimeReq   @default(CLOUD)
  runtimeDetectedBy  DetectionSrc @default(AUTO)
  runtimeReason      String?

  status       TemplateStatus @default(PENDING)
  rejectReason String?

  authorId      String
  useCount      Int    @default(0)
  likeCount     Int    @default(0)
  favoriteCount Int    @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  author      User      @relation("SkillAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([useCount])
  @@index([publishedAt])
}

model mcp_servers {
  id            String       @id @default(cuid())
  title         String       @db.VarChar(200)
  description   String?
  category      String       @db.VarChar(50)
  rawConfig     Json?
  configFormat  String       @default("mcp_json") @db.VarChar(50)
  serverName    String       @db.VarChar(100)
  transport     McpTransport
  command       String?
  args          String[]     @default([])
  envSchema     Json?
  headersSchema Json?
  authSchema    Json?
  tools         Json?
  capabilities  Json?
  installNotes  String?      @db.Text
  securityNotes String?      @db.Text
  url           String?
  coverImage    String?
  exampleMedia  String[]     @default([])
  tags          String[]     @default([])
  version       Int          @default(1)

  pointsCost Int @default(0)

  runtimeRequirement RuntimeReq   @default(DESKTOP_ONLY)
  runtimeDetectedBy  DetectionSrc @default(AUTO)
  runtimeReason      String?

  status       TemplateStatus @default(PENDING)
  rejectReason String?

  authorId      String
  useCount      Int    @default(0)
  likeCount     Int    @default(0)
  favoriteCount Int    @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  author      User      @relation("McpServerAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([useCount])
  @@index([publishedAt])
}

model agents {
  id           String   @id @default(cuid())
  title        String   @db.VarChar(200)
  description  String?
  category     String   @db.VarChar(50)
  systemPrompt String   @db.Text
  toolBindings Json
  defaultModel String?  @db.VarChar(100)
  variables    Json
  coverImage   String?
  exampleMedia String[] @default([])
  tags         String[] @default([])
  version      Int      @default(1)

  kind          AgentKind          @default(chat)
  isSystem      Boolean            @default(false)
  executionMode AgentExecutionMode @default(single)

  pointsCost Int @default(0)

  runtimeRequirement RuntimeReq   @default(CLOUD)
  runtimeDetectedBy  DetectionSrc @default(AUTO)
  runtimeReason      String?

  status       TemplateStatus @default(PENDING)
  rejectReason String?

  authorId      String
  useCount      Int    @default(0)
  likeCount     Int    @default(0)
  favoriteCount Int    @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  workflow               agent_workflows?
  author                 User             @relation("AgentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  runs                   agent_runs[]
  conversationsAsDefault conversations[]  @relation("ConversationAgent")

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([useCount])
  @@index([publishedAt])
}

// 图片生成流水（由原 template_generations 重命名而来）
model image_generations {
  id              String          @id @default(cuid())
  templateId      String
  template        image_templates @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId          String
  user            User            @relation("ImageGenerationUser", fields: [userId], references: [id], onDelete: Cascade)
  modelUsed       String          @db.VarChar(100)
  resolvedPrompt  String
  variables       Json?
  referenceImage  String?
  generatedImages String[]        @default([])
  status          String          @default("pending")
  error           String?
  durationMs      Int?
  createdAt       DateTime        @default(now())

  @@index([templateId])
  @@index([userId])
}

model video_generations {
  id              String          @id @default(cuid())
  templateId      String
  template        video_templates @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId          String
  user            User            @relation("VideoGenerationUser", fields: [userId], references: [id], onDelete: Cascade)
  modelUsed       String          @db.VarChar(100)
  resolvedPrompt  String
  variables       Json?
  referenceImage  String?
  generatedVideos String[]        @default([])
  status          String          @default("pending")
  error           String?
  durationMs      Int?
  createdAt       DateTime        @default(now())

  @@index([templateId])
  @@index([userId])
}

// 图片/视频共用一张多轮记录表（polymorphic：用 generationType + generationId 关联）
model generation_turns {
  id             String       @id @default(cuid())
  generationType ResourceType // 仅 IMAGE_TEMPLATE / VIDEO_TEMPLATE
  generationId   String
  role           MessageRole
  content        String
  images         String[]     @default([])
  createdAt      DateTime     @default(now())

  @@index([generationType, generationId])
}

// 一次性获取记录（Skills / MCP / Agents 用）
model user_resource_acquisitions {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation("ResourceAcquisitionUser", fields: [userId], references: [id], onDelete: Cascade)
  resourceType ResourceType
  resourceId   String
  pointsPaid   Int
  acquiredAt   DateTime     @default(now())

  @@unique([userId, resourceType, resourceId])
  @@index([userId, resourceType])
}

// 收藏（5 类资源通用）
model resource_favorites {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation("ResourceFavoriteUser", fields: [userId], references: [id], onDelete: Cascade)
  resourceType ResourceType
  resourceId   String
  createdAt    DateTime     @default(now())

  @@unique([userId, resourceType, resourceId])
  @@index([userId, createdAt])
}

// 浏览历史（5 类资源通用）
model resource_views {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation("ResourceViewUser", fields: [userId], references: [id], onDelete: Cascade)
  resourceType ResourceType
  resourceId   String
  viewedAt     DateTime     @default(now())

  @@index([userId, viewedAt])
  @@index([resourceType, resourceId])
}

// 会话激活的资源（A2 模式：仅 SKILL / AGENT / MCP）
model conversation_resources {
  id             String        @id @default(cuid())
  conversationId String
  conversation   conversations @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  resourceType   ResourceType
  resourceId     String
  activatedAt    DateTime      @default(now())
  activatedBy    String
  activator      User          @relation("ConversationResourceActivator", fields: [activatedBy], references: [id], onDelete: Restrict)

  @@unique([conversationId, resourceType, resourceId])
  @@index([conversationId])
}

// ── Membership & Points ───────────────────────────────────────────────────

enum PointsRecordType {
  EARN
  CONSUME
}

enum PointsSource {
  MEMBERSHIP
  PACKAGE
  TASK
  INVITATION
  ADMIN_GRANT
  AGENT_CALL
  CONTRIBUTION
}

enum OrderType {
  MEMBERSHIP
  POINTS_PACKAGE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model membership_levels {
  id             String             @id @default(cuid())
  name           String
  level          Int                @unique
  monthlyPrice   Decimal            @db.Decimal(10, 2)
  pointsPerMonth Int
  features       Json?
  isActive       Boolean            @default(true)
  sort           Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  plans          membership_plans[]
  memberships    user_memberships[]

  @@index([isActive, sort])
}

model membership_plans {
  id             String            @id @default(cuid())
  levelId        String
  level          membership_levels @relation(fields: [levelId], references: [id])
  billingCycle   BillingCycle
  months         Int
  autoRenew      Boolean           @default(false)
  originalPrice  Decimal           @db.Decimal(10, 2)
  price          Decimal           @db.Decimal(10, 2)
  firstTimePrice Decimal?          @db.Decimal(10, 2)
  discountLabel  String?
  firstTimeLabel String?
  points         Int
  isActive       Boolean           @default(true)
  sort           Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([levelId, billingCycle, autoRenew])
  @@index([isActive, sort])
}

model user_memberships {
  id        String            @id @default(cuid())
  userId    String            @unique
  user      User              @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  levelId   String
  level     membership_levels @relation(fields: [levelId], references: [id])
  planId    String?
  autoRenew Boolean           @default(false)
  startedAt DateTime          @default(now())
  expiresAt DateTime
  status    MembershipStatus  @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model points_packages {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  points    Int
  isActive  Boolean  @default(true)
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sort])
}

model user_points {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation("UserPointsUser", fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model points_records {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation("PointsRecordUser", fields: [userId], references: [id], onDelete: Cascade)
  type      PointsRecordType
  amount    Int
  source    PointsSource
  sourceId  String?
  balance   Int
  remark    String?
  status    PointsRecordStatus @default(CONFIRMED)
  holdId    String?
  createdAt DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([source])
  @@index([status])
  @@index([holdId])
}

model orders {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation("OrderUser", fields: [userId], references: [id], onDelete: Restrict)
  orderNo       String      @unique
  orderType     OrderType
  productId     String
  productName   String
  originalPrice Decimal     @db.Decimal(10, 2)
  amount        Decimal     @db.Decimal(10, 2)
  isFirstTime   Boolean     @default(false)
  status        OrderStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([orderNo])
}

model invite_codes {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation("InviteCodeUser", fields: [userId], references: [id], onDelete: Cascade)
  code      String           @unique
  createdAt DateTime         @default(now())
  records   invite_records[]

  @@index([code])
}

model invite_records {
  id            String   @id @default(cuid())
  inviteCodeId  String
  inviterUserId String
  inviteeUserId String
  rewardPoints  Int      @default(0)
  rewarded      Boolean  @default(false)
  createdAt     DateTime @default(now())

  inviteCode invite_codes @relation(fields: [inviteCodeId], references: [id])
  inviter    User         @relation("InviteRecordInviter", fields: [inviterUserId], references: [id], onDelete: Restrict)
  invitee    User         @relation("InviteRecordInvitee", fields: [inviteeUserId], references: [id], onDelete: Restrict)

  @@unique([inviteeUserId])
  @@index([inviterUserId])
}

model task_point_costs {
  id        String   @id @default(cuid())
  taskType  String   @unique
  name      String
  cost      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model amux_credentials {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation("AmuxCredentialUser", fields: [userId], references: [id], onDelete: Cascade)
  host       String   @db.VarChar(500)
  oat        String   @db.VarChar(500)
  amuxUserId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Agent Workflow Engine ─────────────────────────────────────────────────

enum AgentKind {
  chat
  image
  video
  avatar
}

enum AgentExecutionMode {
  single
  workflow
}

enum ExecutorType {
  deepagent
  llm_chain
}

enum AgentRunStatus {
  pending
  running
  paused_user_confirm
  paused_user_stop
  paused_failure
  completed
  cancelled
  archived
}

enum AgentRunStepStatus {
  pending
  running
  validating
  critiquing
  refining
  completed
  failed
  cancelled
}

enum AgentRunDepthMode {
  standard
  deep
}

enum PointsRecordStatus {
  PENDING
  CONFIRMED
  REFUNDED
}

model agent_workflows {
  id        String                 @id @default(cuid())
  agentId   String                 @unique
  agent     agents                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
  isDefault Boolean                @default(false)
  version   Int                    @default(1)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  steps     agent_workflow_steps[]
  runs      agent_runs[]

  @@index([agentId])
}

model agent_workflow_steps {
  id                   String          @id @default(cuid())
  workflowId           String
  workflow             agent_workflows @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepKey              String
  displayName          String
  isOptional           Boolean         @default(false)
  sortOrder            Int
  dependencies         String[]        @default([])
  inputArtifactKeys    String[]        @default([])
  executorType         ExecutorType    @default(deepagent)
  artifactType         ArtifactType
  promptTemplate       String          @db.Text
  toolBindings         Json?
  validationSchema     Json?
  criticEnabled        Boolean         @default(false)
  criticPromptTemplate String?         @db.Text
  criticModelConfigId  String?
  criticPassThreshold  Decimal?        @db.Decimal(4, 2)
  maxRefineAttempts    Int             @default(2)

  @@unique([workflowId, stepKey])
  @@index([workflowId, sortOrder])
}

model agent_runs {
  id                String                    @id @default(cuid())
  conversationId    String
  conversation      conversations             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentId           String
  agent             agents                    @relation(fields: [agentId], references: [id])
  workflowId        String
  workflow          agent_workflows           @relation(fields: [workflowId], references: [id])
  status            AgentRunStatus            @default(pending)
  targetStepKey     String?
  currentStepKey    String?
  modelConfigId     String
  deepagentThreadId String?
  depthMode         AgentRunDepthMode         @default(standard)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  steps             agent_run_steps[]
  stepArtifacts     workflow_step_artifacts[]

  @@index([conversationId, status])
  @@index([conversationId, createdAt])
}

model agent_run_steps {
  id                 String             @id @default(cuid())
  runId              String
  run                agent_runs         @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepKey            String
  attempt            Int                @default(1)
  status             AgentRunStepStatus @default(pending)
  artifactStepId     String?
  proposedNextStep   String?
  proposalReasoning  String?            @db.Text
  validationAttempts Int                @default(0)
  criticAttempts     Int                @default(0)
  lastCriticScore    Decimal?           @db.Decimal(4, 2)
  lastCriticFeedback String?            @db.Text
  error              String?
  startedAt          DateTime?
  completedAt        DateTime?

  @@unique([runId, stepKey, attempt])
  @@index([runId])
}

model workflow_step_artifacts {
  id          String       @id @default(cuid())
  runId       String
  run         agent_runs   @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepKey     String
  content     String       @db.Text
  contentType ArtifactType
  version     Int
  createdAt   DateTime     @default(now())

  @@unique([runId, stepKey, version])
  @@index([runId, stepKey])
}

// ── Video Agent ──────────────────────────────────────────────────────────────

enum VideoProjectStatus {
  draft
  generating
  completed
  failed
}

enum VideoClipStatus {
  pending
  generating
  completed
  failed
}

enum VideoMaterialRole {
  first_frame
  last_frame
  reference_image
  reference_video
  reference_audio
}

enum VideoMaterialSourceType {
  upload
  image_generation
  video_generation
  platform_asset
}

enum VideoGenStatus {
  pending
  queued
  running
  completed
  failed
  expired
}

model video_projects {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation("VideoProjectUser", fields: [userId], references: [id], onDelete: Cascade)
  title          String             @db.VarChar(200)
  conversationId String?            @unique
  coverImage     String?
  status         VideoProjectStatus @default(draft)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  conversation conversations? @relation(fields: [conversationId], references: [id])
  clips        video_clips[]

  @@index([userId, updatedAt])
}

model video_clips {
  id            String          @id @default(cuid())
  projectId     String
  order         Int
  title         String?         @db.VarChar(100)
  prompt        String?
  params        Json
  chainFromPrev Boolean         @default(false)
  status        VideoClipStatus @default(pending)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project     video_projects           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materials   video_clip_materials[]
  generations video_clip_generations[]

  @@unique([projectId, order])
  @@index([projectId])
}

model video_clip_materials {
  id         String                  @id @default(cuid())
  clipId     String
  role       VideoMaterialRole
  sourceType VideoMaterialSourceType
  sourceId   String?
  url        String
  name       String?                 @db.VarChar(200)
  metadata   Json?
  createdAt  DateTime                @default(now())

  clip video_clips @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId])
}

model video_clip_generations {
  id                 String         @id @default(cuid())
  clipId             String
  projectId          String
  userId             String
  user               User           @relation("VideoClipGenerationUser", fields: [userId], references: [id], onDelete: Cascade)
  variantLabel       String?        @db.VarChar(50)
  model              String         @db.VarChar(100)
  resolvedPrompt     String
  params             Json
  seedanceTaskId     String?        @db.VarChar(200)
  status             VideoGenStatus @default(pending)
  videoUrl           String?
  lastFrameUrl       String?
  thumbnailUrl       String?
  durationSec        Float?
  error              String?
  externalStatus     String?        @db.VarChar(50)
  callbackReceivedAt DateTime?
  createdAt          DateTime       @default(now())
  completedAt        DateTime?

  clip video_clips @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([projectId])
  @@index([userId, createdAt])
  @@index([seedanceTaskId])
}

model video_workflow_templates {
  id          String         @id @default(cuid())
  title       String         @db.VarChar(200)
  description String?
  category    String         @db.VarChar(50)
  coverImage  String?
  tags        String[]       @default([])
  clips       Json
  authorId    String
  author      User           @relation("VideoWorkflowTemplateAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  status      TemplateStatus @default(PENDING)
  useCount    Int            @default(0)
  pointsCost  Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([category])
}
