enum ExecutorType {
  deepagent
  llm_chain
}

enum AgentRunStatus {
  pending
  running
  paused_user_confirm
  paused_user_stop
  paused_failure
  completed
  cancelled
  archived
}

enum AgentRunStepStatus {
  pending
  running
  validating
  critiquing
  refining
  completed
  failed
  cancelled
}

