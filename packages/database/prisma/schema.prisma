  @@index([userId, createdAt])
  @@index([source])
  @@index([status])
  @@index([holdId])
}

model orders {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation("OrderUser", fields: [userId], references: [id], onDelete: Restrict)
  orderNo           String             @unique
  orderType         OrderType
  businessType      OrderBusinessType?
  productId         String
  productName       String
