model agent_workflows {
  id        String                 @id @default(cuid())
  agentId   String                 @unique
  agent     agents                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
  isDefault Boolean                @default(false)
  version   Int                    @default(1)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  steps     agent_workflow_steps[]
  runs      agent_runs[]

  @@index([agentId])
}

model agent_workflow_steps {
  id                   String          @id @default(cuid())
  workflowId           String
  workflow             agent_workflows @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepKey              String
  displayName          String
  isOptional           Boolean         @default(false)
  sortOrder            Int
  dependencies         String[]        @default([])
  inputArtifactKeys    String[]        @default([])
  executorType         ExecutorType    @default(deepagent)
  artifactType         ArtifactType
  promptTemplate       String          @db.Text
  toolBindings         Json?
  validationSchema     Json?
  criticEnabled        Boolean         @default(false)
  criticPromptTemplate String?         @db.Text
  criticModelConfigId  String?
  criticPassThreshold  Decimal?        @db.Decimal(4, 2)
  maxRefineAttempts    Int             @default(2)

  @@unique([workflowId, stepKey])
  @@index([workflowId, sortOrder])
}

model agent_runs {
  id                String                    @id @default(cuid())
  conversationId    String
  conversation      conversations             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentId           String
  agent             agents                    @relation(fields: [agentId], references: [id])
  workflowId        String
  workflow          agent_workflows           @relation(fields: [workflowId], references: [id])
  status            AgentRunStatus            @default(pending)
  targetStepKey     String?
  currentStepKey    String?
  modelConfigId     String
  deepagentThreadId String?
  depthMode         AgentRunDepthMode         @default(standard)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  steps             agent_run_steps[]
  stepArtifacts     workflow_step_artifacts[]

  @@index([conversationId, status])
  @@index([conversationId, createdAt])
}

model agent_run_steps {
  id                 String             @id @default(cuid())
  runId              String
  run                agent_runs         @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepKey            String
  attempt            Int                @default(1)
  status             AgentRunStepStatus @default(pending)
  artifactStepId     String?
  proposedNextStep   String?
  proposalReasoning  String?            @db.Text
  validationAttempts Int                @default(0)
  criticAttempts     Int                @default(0)
  lastCriticScore    Decimal?           @db.Decimal(4, 2)
  lastCriticFeedback String?            @db.Text
  error              String?
  startedAt          DateTime?
  completedAt        DateTime?

  @@unique([runId, stepKey, attempt])
  @@index([runId])
}

model workflow_step_artifacts {
  id          String       @id @default(cuid())
  runId       String
  run         agent_runs   @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepKey     String
  content     String       @db.Text
  contentType ArtifactType
  version     Int
  createdAt   DateTime     @default(now())

  @@unique([runId, stepKey, version])
  @@index([runId, stepKey])
}

// ── Video Agent ──────────────────────────────────────────────────────────────

enum VideoProjectStatus {
  draft
  generating
  completed
  failed
}

enum VideoClipStatus {
  pending
  generating
  completed
  failed
}

enum VideoMaterialRole {
  first_frame
  last_frame
  reference_image
  reference_video
  reference_audio
}

enum VideoMaterialSourceType {
  upload
  image_generation
  video_generation
  platform_asset
}

enum VideoGenStatus {
  pending
  queued
  running
  completed
  failed
  expired
}

model video_projects {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation("VideoProjectUser", fields: [userId], references: [id], onDelete: Cascade)
  title          String             @db.VarChar(200)
  conversationId String?            @unique
  coverImage     String?
  status         VideoProjectStatus @default(draft)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  conversation conversations?         @relation(fields: [conversationId], references: [id])
  clips        video_clips[]
  shares       video_project_shares[]

  @@index([userId, updatedAt])
}

model video_project_shares {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(16)
  projectId String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project video_projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId, createdAt])
}

model video_clips {
  id            String          @id @default(cuid())
  projectId     String
  order         Int
  title         String?         @db.VarChar(100)
  prompt        String?
  params        Json
  chainFromPrev Boolean         @default(false)
  status        VideoClipStatus @default(pending)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project     video_projects           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materials   video_clip_materials[]
  generations video_clip_generations[]

  @@unique([projectId, order])
  @@index([projectId])
}

model video_clip_materials {
  id         String                  @id @default(cuid())
  clipId     String
  role       VideoMaterialRole
  sourceType VideoMaterialSourceType
  sourceId   String?
  url        String
  name       String?                 @db.VarChar(200)
  metadata   Json?
  createdAt  DateTime                @default(now())

  clip video_clips @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId])
}

model video_clip_generations {
  id                 String         @id @default(cuid())
  clipId             String
  projectId          String
  userId             String
  user               User           @relation("VideoClipGenerationUser", fields: [userId], references: [id], onDelete: Cascade)
  variantLabel       String?        @db.VarChar(50)
  model              String         @db.VarChar(100)
  resolvedPrompt     String
  params             Json
  seedanceTaskId     String?        @db.VarChar(200)
  status             VideoGenStatus @default(pending)
  videoUrl           String?
  lastFrameUrl       String?
  thumbnailUrl       String?
  durationSec        Float?
  error              String?
  externalStatus     String?        @db.VarChar(50)
  callbackReceivedAt DateTime?
  createdAt          DateTime       @default(now())
  completedAt        DateTime?

  clip video_clips @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([projectId])
  @@index([userId, createdAt])
  @@index([seedanceTaskId])
}

enum MaterialLibrarySource {
  UPLOAD
  FAVORITE
  HISTORY
}

model material_assets {
  id                 String                @id @default(cuid())
  userId             String
  user               User                  @relation("MaterialAssetUser", fields: [userId], references: [id], onDelete: Cascade)
  type               String                @db.VarChar(24)
  title              String                @db.VarChar(200)
  url                String?
  thumbnailUrl       String?
  mimeType           String?               @db.VarChar(120)
  size               Int?
  storageKey         String?               @db.VarChar(500)
  sourceType         String                @db.VarChar(40)
  librarySource      MaterialLibrarySource
  sourceResourceType ResourceType?
  sourceId           String?
  tags               String[]              @default([])
  metadata           Json?
  folderId           String?
  folder             material_folders?     @relation("MaterialAssetFolder", fields: [folderId], references: [id], onDelete: SetNull)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deletedAt          DateTime?

  @@unique([userId, librarySource, sourceResourceType, sourceId])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([userId, deletedAt])
  @@index([userId, folderId, deletedAt])
  @@index([userId, librarySource, deletedAt, createdAt])
}

model material_folders {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("MaterialFolderUser", fields: [userId], references: [id], onDelete: Cascade)
  name      String    @db.VarChar(100)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assets material_assets[] @relation("MaterialAssetFolder")

  @@index([userId, deletedAt, sortOrder])
}

model video_workflow_templates {
  id          String         @id @default(cuid())
  title       String         @db.VarChar(200)
  description String?
  category    String         @db.VarChar(50)
  coverImage  String?
  tags        String[]       @default([])
  clips       Json
  authorId    String
  author      User           @relation("VideoWorkflowTemplateAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  status      TemplateStatus @default(PENDING)
  useCount    Int            @default(0)
  pointsCost  Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([category])
}

model admin_audit_logs {
  id        String   @id @default(cuid())
  action    String   @db.VarChar(100)
  actorId   String   @db.VarChar(100)
  at        DateTime @default(now())
  payload   Json?
  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([createdAt])
}

// ─── Creative Canvas ────────────────────────────────────────────────────
// Snapshot + reference-index + action-table design (see
// docs/infinite-canvas-integrated-technical-plan.md §6). `revision` is the
// optimistic-concurrency token; snapshot `version` is the milestone number.

model canvas_boards {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation("CanvasBoardUser", fields: [userId], references: [id], onDelete: Cascade)
  title                String
  description          String?
  coverStorageKey      String?
  visibility           String    @default("private")
  status               String    @default("active")
  revision             Int       @default(1)
  latestStateUpdatedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  snapshots canvas_board_snapshots[]
  actions   canvas_board_actions[]
  assetRefs canvas_board_asset_refs[]

  @@index([userId, updatedAt])
}

model canvas_board_snapshots {
  id                  String        @id @default(cuid())
  boardId             String
  board               canvas_boards @relation(fields: [boardId], references: [id], onDelete: Cascade)
  version             Int
  state               Json
  thumbnailStorageKey String?
  pinned              Boolean       @default(false)
  createdAt           DateTime      @default(now())

  @@unique([boardId, version])
  @@index([boardId, createdAt])
}

model canvas_board_actions {
  id                 String        @id @default(cuid())
  boardId            String
  board              canvas_boards @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId             String
  actionType         String
  status             String        @default("pending")
  idempotencyKey     String?
  inputNodeIds       Json?
  outputNodeIds      Json?
  placeholderNodeIds Json?
  request            Json?
  result             Json?
  error              String?
  estimatedCost      Int?
  relatedHoldId      String?
  relatedTaskId      String?
  relatedEntityType  String?
  relatedEntityId    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([boardId, idempotencyKey])
  @@index([boardId, createdAt])
  @@index([userId, status])
}

model canvas_board_asset_refs {
  id          String        @id @default(cuid())
  boardId     String
  board       canvas_boards @relation(fields: [boardId], references: [id], onDelete: Cascade)
  refType     String
  refId       String?
  storageKey  String?
  externalUrl String?
  nodeId      String
  createdAt   DateTime      @default(now())

  @@index([boardId, refType])
  @@index([refType, refId])
}

// ============================================================
// Gallery（广场）+ Resource Metrics（统一指标）+ Operations（运营位/加热）
// 见 docs/gallery-design.md §五。外部引用（author/template/generation/post）一律弱引用
// （无 @relation），存在性由 Service 校验，避免触及 User/模板/生成等既有模型。
// 复用既有表：resource_likes / resource_favorites / resource_views / admin_audit_logs。
// ============================================================

enum GalleryKind {
  IMAGE
  VIDEO
}

enum GalleryStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  HIDDEN
  REMOVED
  UNPUBLISHED
}

enum GallerySource {
  USER_UPLOAD
  FROM_GENERATION
  FROM_TEMPLATE
}

enum FeaturedSlotKind {
  RESOURCE
  CUSTOM
}

enum BoostReason {
  MANUAL
  CAMPAIGN
  EDITORIAL_PICK
  CORRECTION
}

enum GalleryReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model gallery_posts {
  id          String      @id @default(cuid())
  kind        GalleryKind
  title       String?     @db.VarChar(200)
  description String?
  category    String      @db.VarChar(50)
  tags        String[]    @default([])

  coverImage  String?
  mediaUrls   String[] @default([])
  aspectRatio String?  @db.VarChar(20)
  durationSec Int?

  // 作品创作元数据（导入 / 生成来源填充）：提示词、生成模型、原始像素宽高、参考图。
  prompt         String?
  model          String? @db.VarChar(100)
  width          Int?
  height         Int?
  referenceImage String?

  sourceType        GallerySource @default(USER_UPLOAD)
  imageTemplateId   String?
  videoTemplateId   String?
  imageGenerationId String?
  videoGenerationId String?

  status       GalleryStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  rejectReason String?       @db.VarChar(500)
  isFeatured   Boolean       @default(false)
  isPinned     Boolean       @default(false)

  authorId String
  author   User   @relation("GalleryPostAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  sourceForImageTemplate image_templates? @relation("ImageTemplateSourceGallery")

  @@index([status, publishedAt(sort: Desc), id(sort: Desc)])
  @@index([status, kind, publishedAt(sort: Desc), id(sort: Desc)])
  @@index([category])
  @@index([isFeatured])
  @@index([authorId])
  @@index([imageTemplateId])
  @@index([videoTemplateId])
}

model gallery_comments {
  id        String   @id @default(cuid())
  postId    String
  userId    String?
  parentId  String?
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([userId])
}

model gallery_reports {
  id           String              @id @default(cuid())
  postId       String
  reporterId   String?
  reason       String              @db.VarChar(500)
  status       GalleryReportStatus @default(PENDING)
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())

  @@index([status, createdAt])
  @@index([postId])
}

model resource_metrics {
  resourceType ResourceType
  resourceId   String

  pvCount        Int @default(0)
  uvCount        Int @default(0)
  viewCount      Int @default(0)
  likeCount      Int @default(0)
  favoriteCount  Int @default(0)
  commentCount   Int @default(0)
  shareCount     Int @default(0)
  referenceCount Int @default(0)
  citationCount  Int @default(0)
  downloadCount  Int @default(0)

  hotScore        Float     @default(0)
  hotScoreVersion String?
  boostScore      Float     @default(0)
  boostExpiresAt  DateTime?

  firstSeenAt    DateTime @default(now())
  lastActivityAt DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@id([resourceType, resourceId])
  @@index([resourceType, hotScore(sort: Desc), resourceId(sort: Desc)])
  @@index([resourceType, pvCount(sort: Desc)])
  @@index([resourceType, likeCount(sort: Desc)])
  @@index([boostExpiresAt])
}

model resource_view_events {
  id           String       @id @default(cuid())
  resourceType ResourceType
  resourceId   String
  scope        String       @db.VarChar(20)
  viewerKey    String       @db.VarChar(80)
  userId       String?
  visitorId    String?      @db.VarChar(64)
  sessionId    String?      @db.VarChar(64)
  minuteBucket Int
  dayBucket    Int
  createdAt    DateTime     @default(now())

  @@unique([resourceType, resourceId, viewerKey, minuteBucket, scope])
  @@index([resourceType, resourceId, dayBucket])
}

/// 资源下载事件流水（追加式）：与 resource_metrics.downloadCount 配合，前者是明细/审计，后者是聚合计数。
model resource_download_events {
  id           String       @id @default(cuid())
  resourceType ResourceType
  resourceId   String
  userId       String
  createdAt    DateTime     @default(now())

  @@index([resourceType, resourceId, createdAt])
  @@index([userId, createdAt])
}

model resource_uv_days {
  resourceType ResourceType
  resourceId   String
  viewerKey    String       @db.VarChar(80)
  dayBucket    Int
  firstScope   String       @db.VarChar(20)
  createdAt    DateTime     @default(now())

  @@id([resourceType, resourceId, viewerKey, dayBucket])
  @@index([resourceType, resourceId, dayBucket])
}

model resource_metric_daily_stats {
  resourceType ResourceType
  resourceId   String
  dayBucket    Int
  pvCount      Int          @default(0)
  uvCount      Int          @default(0)
  viewCount    Int          @default(0)
  updatedAt    DateTime     @updatedAt

  @@id([resourceType, resourceId, dayBucket])
  @@index([dayBucket])
}

model resource_reference_events {
  id           String       @id @default(cuid())
  resourceType ResourceType
  resourceId   String
  refType      String       @db.VarChar(30)
  refUserId    String?
  refPayload   Json?
  createdAt    DateTime     @default(now())

  @@index([resourceType, resourceId, createdAt])
}

model resource_boosts {
  id           String       @id @default(cuid())
  resourceType ResourceType
  resourceId   String
  boostScore   Float
  reason       BoostReason  @default(MANUAL)
  note         String?      @db.VarChar(500)
  startsAt     DateTime     @default(now())
  endsAt       DateTime
  isActive     Boolean      @default(true)
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([resourceType, resourceId, isActive])
  @@index([endsAt])
}

model featured_slots {
  id           String           @id @default(cuid())
  placement    String           @db.VarChar(40)
  kind         FeaturedSlotKind
  resourceType ResourceType?
  resourceId   String?

  overrideTitle       String? @db.VarChar(200)
  overrideDescription String? @db.VarChar(500)
  overrideCoverImage  String?
  overrideCoverVideo  String?
  overrideCtaText     String? @db.VarChar(50)
  overrideCtaHref     String? @db.VarChar(500)

  position  Int       @default(0)
  isEnabled Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([placement, position])
  @@index([placement, isEnabled, position])
  @@index([resourceType, resourceId])
  @@index([startsAt, endsAt])
}
