// ── Membership & Points ───────────────────────────────────────────────────

enum PointsRecordType {
  EARN
  CONSUME
}

enum PointsSource {
  MEMBERSHIP
  PACKAGE
  TASK
  INVITATION
  ADMIN_GRANT
  AGENT_CALL
  CONTRIBUTION
  CAMPAIGN
  EXPIRATION
}

enum OrderType {
  MEMBERSHIP
  POINTS_PACKAGE
}

enum OrderBusinessType {
  subscription_order
  points_order
  renewal_order
  upgrade_order
  refund_order
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model membership_levels {
  id                    String                           @id @default(cuid())
  name                  String
  level                 Int                              @unique
  monthlyPrice          Decimal                          @db.Decimal(10, 2)
  pointsPerMonth        Int
  features              Json?
  isActive              Boolean                          @default(true)
  sort                  Int                              @default(0)
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  modelConfigAllowances model_config_membership_levels[]
  plans                 membership_plans[]
  memberships           user_memberships[]

  @@index([isActive, sort])
}

model membership_plans {
  id             String            @id @default(cuid())
  levelId        String
  level          membership_levels @relation(fields: [levelId], references: [id])
  billingCycle   BillingCycle
  months         Int
  autoRenew      Boolean           @default(false)
  originalPrice  Decimal           @db.Decimal(10, 2)
  price          Decimal           @db.Decimal(10, 2)
  firstTimePrice Decimal?          @db.Decimal(10, 2)
  discountLabel  String?
  firstTimeLabel String?
  points         Int
  isActive       Boolean           @default(true)
  sort           Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([levelId, billingCycle, autoRenew])
  @@index([isActive, sort])
}

model user_memberships {
  id                       String            @id @default(cuid())
  userId                   String            @unique
  user                     User              @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  levelId                  String
  level                    membership_levels @relation(fields: [levelId], references: [id])
  planId                   String?
  autoRenew                Boolean           @default(false)
  startedAt                DateTime          @default(now())
  expiresAt                DateTime
  status                   MembershipStatus  @default(ACTIVE)
  cancelAtPeriodEnd        Boolean           @default(false)
  cancelledAt              DateTime?
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  pendingPlanId            String?
  pendingOrderId           String?
  pendingLevelId           String?
  pendingBillingCycle      BillingCycle?
  pendingAutoRenew         Boolean?
  pendingChangeEffectiveAt DateTime?
  pendingChangeRequestedAt DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([pendingChangeEffectiveAt])
  @@index([stripeSubscriptionId])
}

model points_packages {
  id                    String   @id @default(cuid())
