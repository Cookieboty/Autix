  refundAmount      Decimal?           @db.Decimal(10, 2)
  refundReason      String?
  refundMetadata    Json?
  refundedAt        DateTime?
  paymentEvents     payment_events[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId, createdAt])
  @@index([orderNo])
  @@index([businessType])
  @@index([fulfilledAt])
  @@index([paymentProvider, externalPaymentId])
  @@index([paymentEventId])
  @@index([refundedAt])
}

model payment_events {
  id                String    @id @default(cuid())
  provider          String
  eventId           String
  eventType         String
  orderId           String?
  order             orders?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  userId            String?
  user              User?     @relation("PaymentEventOrderUser", fields: [userId], references: [id], onDelete: SetNull)
  orderNo           String?
  externalPaymentId String?
  amount            Decimal?  @db.Decimal(10, 2)
  currency          String?
  status            String    @default("PENDING")
  payload           Json?
  errorMessage      String?
  processedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([provider, eventId])
  @@index([orderId])
  @@index([userId])
  @@index([orderNo])
  @@index([status, createdAt])
}

model invite_codes {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation("InviteCodeUser", fields: [userId], references: [id], onDelete: Cascade)
  code      String           @unique
  createdAt DateTime         @default(now())
