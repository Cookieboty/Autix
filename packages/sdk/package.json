      "types": "./src/ai-ui-api.ts",
      "import": "./src/ai-ui-api.ts"
    },
    "./amux-import": {
      "types": "./src/amux-import.ts",
      "import": "./src/amux-import.ts"
    },
    "./auth": {
      "types": "./src/modules/auth.api.ts",
      "import": "./src/modules/auth.api.ts"
    },
    "./user": {
      "types": "./src/modules/user.api.ts",
      "import": "./src/modules/user.api.ts"
    },
    "./conversation": {
      "types": "./src/modules/conversation.api.ts",
      "import": "./src/modules/conversation.api.ts"
    },
    "./video": {
      "types": "./src/modules/video.api.ts",
      "import": "./src/modules/video.api.ts"
    },
    "./image": {
      "types": "./src/modules/image.api.ts",
      "import": "./src/modules/image.api.ts"
    },
    "./marketplace": {
      "types": "./src/modules/marketplace.api.ts",
