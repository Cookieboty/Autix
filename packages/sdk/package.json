    },
    "./document": {
      "types": "./src/modules/document.api.ts",
      "import": "./src/modules/document.api.ts"
    },
    "./admin": {
      "types": "./src/modules/admin.api.ts",
      "import": "./src/modules/admin.api.ts"
    }
