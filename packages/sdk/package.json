    },
    "./membership": {
      "types": "./src/modules/membership.api.ts",
      "import": "./src/modules/membership.api.ts"
    },
    "./order": {
      "types": "./src/modules/order.api.ts",
      "import": "./src/modules/order.api.ts"
    },
    "./materials": {
      "types": "./src/modules/materials.api.ts",
