{
  "name": "@autix/ai-adapters",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./image": {
      "bun": "./src/image/index.ts",
      "types": "./dist/image/index.d.ts",
      "default": "./dist/image/index.js"
    },
    "./core": {
      "bun": "./src/core/index.ts",
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "image": ["./dist/image/index.d.ts"],
      "core": ["./dist/core/index.d.ts"]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@autix/shared-lib": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  }
}
