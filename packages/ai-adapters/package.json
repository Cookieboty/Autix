{
  "name": "@autix/ai-adapters",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js"
    },
    "./image": {
      "types": "./dist/image/index.d.ts",
      "import": "./src/image/index.ts",
      "require": "./dist/image/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./src/core/index.ts",
      "require": "./dist/core/index.js"
    },
    "./video": {
      "types": "./dist/video/index.d.ts",
      "import": "./src/video/index.ts",
      "require": "./dist/video/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "image": [
        "./dist/image/index.d.ts"
      ],
      "core": [
        "./dist/core/index.d.ts"
      ],
      "video": [
        "./dist/video/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@autix/domain": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  }
}
