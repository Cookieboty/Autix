{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@autix/domain": ["../domain/dist/index.d.ts"],
      "@autix/domain/*": ["../domain/dist/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.spec.ts"]
}
