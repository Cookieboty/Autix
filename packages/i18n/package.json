{
  "name": "@autix/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && rimraf dist/messages && shx cp -R src/messages dist/messages",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "typescript": "^5.7.0"
  },
  "sideEffects": false
}
