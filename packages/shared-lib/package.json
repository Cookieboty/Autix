{
  "name": "@autix/shared-lib",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "adapters": ["./src/adapters.ts"],
      "api": ["./src/api.ts"],
      "image-capabilities": ["./src/image-capabilities.ts"],
      "image-coerce": ["./src/image-coerce.ts"],
      "image-prompt": ["./src/image-prompt.ts"],
      "utils": ["./src/utils.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./adapters": {
      "types": "./src/adapters.ts",
      "import": "./src/adapters.ts"
    },
    "./api": {
      "types": "./src/api.ts",
      "import": "./src/api.ts"
    },
    "./image-capabilities": {
      "bun": "./src/image-capabilities.ts",
      "types": "./src/image-capabilities.ts",
      "require": "./dist/image-capabilities.js",
      "import": "./src/image-capabilities.ts",
      "default": "./src/image-capabilities.ts"
    },
    "./image-coerce": {
      "bun": "./src/image-coerce.ts",
      "types": "./src/image-coerce.ts",
      "require": "./dist/image-coerce.js",
      "import": "./src/image-coerce.ts",
      "default": "./src/image-coerce.ts"
    },
    "./image-prompt": {
      "bun": "./src/image-prompt.ts",
      "types": "./src/image-prompt.ts",
      "require": "./dist/image-prompt.js",
      "import": "./src/image-prompt.ts",
      "default": "./src/image-prompt.ts"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "import": "./src/utils.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({type:'commonjs'}))\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@autix/i18n": "workspace:*",
    "@autix/platform": "workspace:*",
    "@autix/types": "workspace:*",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
