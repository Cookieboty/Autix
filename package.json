{
  "name": "root",
  "private": true,
  "workspaces": ["clients/*", "services/*", "packages/*"],
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@repo/web",
    "dev:chat": "turbo run dev --filter=@repo/chat",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.17",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20"
  }
}
