{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "clean:ports": "for port in 3100 4000 5173; do lsof -ti :$port | xargs kill -9 2>/dev/null; done; echo 'Ports cleaned'",
    "dev": "pnpm run dev:web",
    "dev:web": "pnpm run clean:ports && turbo run dev --filter=@autix/web --filter=@autix/api",
    "dev:api": "pnpm run clean:ports && pnpm run db:deploy && pnpm run db:seed:pricing && turbo run dev --filter=@autix/api",
    "dev:desktop": "pnpm run clean:ports && pnpm run db:deploy && pnpm run db:seed:pricing && turbo run dev --filter=@autix/desktop --filter=@autix/api",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --concurrency=1 && vitest run --config vitest.root.config.ts",
    "arch:check": "tsx --tsconfig scripts/tsconfig.json scripts/check-architecture-boundaries.ts",
    "i18n:check": "tsx --tsconfig scripts/tsconfig.json scripts/check-i18n-consistency.ts",
    "lint": "eslint .",
    "db:generate": "dotenv -e .env -- pnpm --filter @autix/database run db:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @autix/database run db:migrate",
    "db:deploy": "dotenv -e .env -- pnpm --filter @autix/database run db:deploy",
    "db:push": "dotenv -e .env -- pnpm --filter @autix/database run db:push",
    "db:flat-migrate": "dotenv -e .env -- pnpm --filter @autix/database run db:flat-migrate",
    "db:init-membership": "dotenv -e .env -- pnpm --filter @autix/database run db:init-membership",
    "db:prepare-cutover": "dotenv -e .env -- pnpm --filter @autix/database run db:prepare-cutover",
    "db:seed": "dotenv -e .env -- pnpm --filter @autix/database run db:seed",
    "db:seed:pricing": "pnpm --filter @autix/api run seed:pricing",
    "db:seed:prod": "dotenv -e .env -- pnpm --filter @autix/database run db:seed:prod",
    "db:studio": "dotenv -e .env -- pnpm --filter @autix/database exec prisma studio --schema prisma/schema.prisma",
    "clean:next": "rm -rf clients/web/.next/dev/cache/turbopack",
    "clean:next:dev": "rm -rf clients/web/.next/dev clients/desktop/.next/dev",
    "clean:turbo": "rm -rf .turbo",
    "clean:turbo:cache": "rm -rf .turbo/cache",
    "clean:node_modules": "find . -name node_modules -type d -prune -exec rm -rf {} +",
    "clean:all": "rm -rf clients/web/.next clients/desktop/.next .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.5"
  }
}
