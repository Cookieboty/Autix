{
  "name": "root",
  "private": true,
  "workspaces": ["clients/*", "services/*", "packages/*"],
  "packageManager": "bun@1.3.11",
  "scripts": {
    "clean:ports": "for port in 3100 4000 5173; do lsof -ti :$port | xargs kill -9 2>/dev/null; done; echo 'Ports cleaned'",
    "dev": "bun run dev:web",
    "dev:web": "bun run clean:ports && bun run db:deploy && turbo run dev --filter=@autix/web --filter=@autix/api",
    "dev:api": "bun run clean:ports && bun run db:deploy && turbo run dev --filter=@autix/api",
    "dev:desktop": "bun run clean:ports && bun run db:deploy && turbo run dev --filter=@autix/desktop --filter=@autix/api",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --concurrency=1",
    "arch:check": "bun run scripts/check-architecture-boundaries.ts",
    "lint": "eslint .",
    "db:generate": "dotenv -e .env -- bun run --cwd packages/database db:generate",
    "db:migrate": "dotenv -e .env -- bun run --cwd packages/database db:migrate",
    "db:deploy": "dotenv -e .env -- bun run --cwd packages/database db:deploy",
    "db:push": "dotenv -e .env -- bun run --cwd packages/database db:push",
    "db:flat-migrate": "dotenv -e .env -- bun run --cwd packages/database db:flat-migrate",
    "db:init-membership": "dotenv -e .env -- bun run --cwd packages/database db:init-membership",
    "db:prepare-cutover": "dotenv -e .env -- bun run --cwd packages/database db:prepare-cutover",
    "db:seed": "dotenv -e .env -- bun run --cwd packages/database db:seed",
    "db:seed:prod": "dotenv -e .env -- bun run --cwd packages/database db:seed:prod",
    "db:studio": "dotenv -e .env -- bunx --cwd packages/database prisma studio --schema prisma/schema.prisma",
    "clean:next": "rm -rf clients/web/.next/dev/cache/turbopack",
    "clean:all": "rm -rf clients/web/.next clients/desktop/.next"
  },
  "resolutions": {},
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript-eslint": "^8.0.0",
    "wait-on": "^9.0.5"
  }
}
