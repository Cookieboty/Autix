# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:autix123@localhost:5432/autix?schema=public

# ── One-time flat migration from old split databases ───────
# Set RUN_FLAT_MIGRATION=true only during cutover from the old user_system/autix_chat databases.
RUN_FLAT_MIGRATION=false
FLAT_MIGRATION_TRUNCATE_TARGET=false
LEGACY_USER_DATABASE_URL=
LEGACY_CHAT_DATABASE_URL=

# ── PostgreSQL (docker-compose) ────────────────────────────
POSTGRES_PASSWORD=autix123

# ── JWT (所有服务共享) ─────────────────────────────────────
# ⚠️  必须替换为随机字符串 (>= 32 字符)
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# ── Service ────────────────────────────────────────────────
PORT=4000
API_URL=http://localhost:4000

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,file://,app://desktop

# ── Super Admin (首次启动时自动创建) ──────────────────────
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=
# 设为 true 可在重启时重置超管密码
SUPER_ADMIN_RESET_PASSWORD=false

# ── Frontend (Next.js) ─────────────────────────────────────
WEB_APP_URL=http://localhost:3100
NEXT_PUBLIC_AMUX_HOST=https://api.amux.ai
NEXT_PUBLIC_AMUX_CLIENT_ID=amux-desktop
NEXT_PUBLIC_ENABLE_MODEL_CONFIG=true
NEXT_PUBLIC_ENABLE_AMUX_MODEL_IMPORT=true
# 三方登录注册时归属的 System code(单系统部署留默认即可),默认 chat
NEXT_PUBLIC_SYSTEM_CODE=chat
ENABLE_MODEL_CONFIG=true
ENABLE_AMUX_MODEL_IMPORT=true
ENABLE_CHAT=true
ENABLE_LIBRARY=true

# ── Stripe Payments ────────────────────────────────────────
# Stripe secret key, e.g. sk_live_xxx / sk_test_xxx. Never expose this to frontend code.
STRIPE_SECRET_KEY=
# Set true in local development to require Stripe sandbox/test API keys (sk_test_ / rk_test_).
STRIPE_TEST_MODE=false
# Webhook signing secret from Stripe Dashboard / Stripe CLI, e.g. whsec_xxx.
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=USD
STRIPE_SUCCESS_URL=http://localhost:3100/membership/orders/checkout?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3100/membership/orders/checkout?checkout=cancelled
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# ── Video Generation (可选) ──────────────────────────────────
# 部署的对外公网域名；配置后 Seedance 视频任务会注入 callback_url
# 不配置时仅依赖 cron + 手动 refresh 收敛，本地开发可留空
APP_PUBLIC_URL=
VIDEO_CRON_REFRESH_STALE_AFTER_SECONDS=300
VIDEO_CRON_EXPIRE_DEAD_AFTER_SECONDS=1800
VIDEO_CRON_BATCH_SIZE=50

# ── Cloudflare R2 (可选, 图片存储) ─────────────────────────
DOMAIN=
Account_ID=
S3_API=
Access_key_ID=
Secret_Access_Key=
Cloudflare_Token=
R2_BUCKET_NAME=

# ── SMTP (邮件发送) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Autix <noreply@example.com>"

# ── Rate Limiting ────────────────────────────────────────────
# 0 = disabled (default), positive number = requests per minute
THROTTLE_LIMIT=0

# ── Password Reset & Activation ──────────────────────────────
PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password
ACTIVATION_BASE_URL=http://localhost:3000/activate
# 无邮箱三方用户补充邮箱后的验证落地页(前端 /email/confirm)
EMAIL_VERIFY_BASE_URL=http://localhost:3100/email/confirm

# ── 三方登录 OAuth (Google / Apple / GitHub) ──────────────────
# 一期只开放的 provider(逗号分隔);留空默认 google。未列入的(如 apple,github)
# 在登录页显示为置灰“暂未上线”,且后端拒绝发起。后续上线只需加入此列表 + 配好对应凭证。
OAUTH_LAUNCHED_PROVIDERS=google
# 三方 access/refresh/id token 落库前的 AES-256-GCM 加密密钥;32 字节 hex。
# 生成:openssl rand -hex 32 。缺失时 OAuth 登录在首次加密 token 时报错。
OAUTH_TOKEN_ENC_KEY=
# 允许后端 302 回传一次性 code 的【前端落地页】白名单(逗号分隔,精确 origin+pathname 匹配)。
# 每个允许的 web origin(dev/staging/prod)都必须同时配置 /oauth/callback(整页回退路径)
# 与 /oauth/popup-callback(弹窗中继页)两条;缺前者拦截回退失败,缺后者弹窗流程报 OAUTH_REDIRECT_NOT_ALLOWED。
# channel query 不参与匹配(只比 origin+pathname),无需为它单列。
# 桌面端 127.0.0.1 loopback 自动放行,无需在此列出。
OAUTH_WEB_REDIRECT_ALLOWLIST=http://localhost:3100/oauth/callback,http://localhost:3100/oauth/popup-callback

# Google(OIDC)。REDIRECT_URI = 向 Google Cloud Console 注册的【后端固定回调】。
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3100/api/auth/callback/google

# GitHub(OAuth2)。Authorization callback URL 配下面这个后端回调。
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=http://localhost:3100/api/auth/callback/github

# Apple(Sign in with Apple)。CLIENT_ID = Services ID(如 com.x.svc);
# PRIVATE_KEY = .p8 文件内容(单行存储时用 \n 表示换行,后端读取时会还原)。
# 线上 REDIRECT_URI 必须是 https。
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY=
OAUTH_APPLE_REDIRECT_URI=https://your-domain/api/auth/callback/apple
