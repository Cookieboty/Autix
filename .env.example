# ── Databases ──────────────────────────────────────────────
CHAT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autix_chat?schema=public
USER_DATABASE_URL=postgresql://postgres:password@localhost:5432/user_system

# ── PostgreSQL (docker-compose) ────────────────────────────
POSTGRES_PASSWORD=autix123

# ── JWT (所有服务共享) ─────────────────────────────────────
# ⚠️  必须替换为随机字符串 (>= 32 字符)
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# ── Service Ports ──────────────────────────────────────────
CHAT_PORT=4001
USER_PORT=4002
USER_GRPC_PORT=50051

# ── Inter-service URLs ─────────────────────────────────────
USER_GRPC_URL=localhost:50051
CHAT_API_URL=http://localhost:4001
INTERNAL_SECRET=

# ── CORS ───────────────────────────────────────────────────
# user-system CORS 白名单（逗号分隔）
# 桌面端使用 file:// origin，生产可改用自定义 protocol（如 app://desktop）
USER_CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:5173,file://,app://desktop
# chat service CORS 白名单（逗号分隔）
CORS_ORIGIN=http://localhost:3002,http://localhost:5173,file://,app://desktop

# ── Super Admin (首次启动时自动创建) ──────────────────────
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=
# 设为 true 可在重启时重置超管密码
SUPER_ADMIN_RESET_PASSWORD=false

# ── Frontend (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_CHAT_API_URL=http://localhost:4001
NEXT_PUBLIC_USER_API_URL=http://localhost:4002/api
NEXT_PUBLIC_AMUX_HOST=https://api.amux.ai
NEXT_PUBLIC_AMUX_CLIENT_ID=amux-desktop

# ── Cloudflare R2 (可选, 图片存储) ─────────────────────────
DOMAIN=
Account_ID=
S3_API=
Access_key_ID=
Secret_Access_Key=
Cloudflare_Token=
R2_BUCKET_NAME=

# ── SMTP (邮件发送) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Autix <noreply@example.com>"

# ── Password Reset ────────────────────────────────────────────
PASSWORD_RESET_BASE_URL=http://localhost:3002/reset-password
