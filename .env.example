# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:autix123@localhost:5432/autix?schema=public

# ── One-time flat migration from old split databases ───────
# Set RUN_FLAT_MIGRATION=true only during cutover from the old user_system/autix_chat databases.
RUN_FLAT_MIGRATION=false
FLAT_MIGRATION_TRUNCATE_TARGET=false
LEGACY_USER_DATABASE_URL=
LEGACY_CHAT_DATABASE_URL=

# ── PostgreSQL (docker-compose) ────────────────────────────
POSTGRES_PASSWORD=autix123

# ── JWT (所有服务共享) ─────────────────────────────────────
# ⚠️  必须替换为随机字符串 (>= 32 字符)
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# ── Service ────────────────────────────────────────────────
PORT=4000
API_URL=http://localhost:4000

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,file://,app://desktop

# ── Super Admin (首次启动时自动创建) ──────────────────────
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=
# 设为 true 可在重启时重置超管密码
SUPER_ADMIN_RESET_PASSWORD=false

# ── Frontend (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_AMUX_HOST=https://api.amux.ai
NEXT_PUBLIC_AMUX_CLIENT_ID=amux-desktop

# ── Video Generation (可选) ──────────────────────────────────
# 部署的对外公网域名；配置后 Seedance 视频任务会注入 callback_url
# 不配置时仅依赖 cron + 手动 refresh 收敛，本地开发可留空
APP_PUBLIC_URL=
VIDEO_CRON_REFRESH_STALE_AFTER_SECONDS=300
VIDEO_CRON_EXPIRE_DEAD_AFTER_SECONDS=1800
VIDEO_CRON_BATCH_SIZE=50

# ── Cloudflare R2 (可选, 图片存储) ─────────────────────────
DOMAIN=
Account_ID=
S3_API=
Access_key_ID=
Secret_Access_Key=
Cloudflare_Token=
R2_BUCKET_NAME=

# ── SMTP (邮件发送) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Autix <noreply@example.com>"

# ── Rate Limiting ────────────────────────────────────────────
# 0 = disabled (default), positive number = requests per minute
THROTTLE_LIMIT=0

# ── Password Reset & Activation ──────────────────────────────
PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password
ACTIVATION_BASE_URL=http://localhost:3000/activate
