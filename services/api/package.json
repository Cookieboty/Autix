{
  "name": "@autix/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "build": "rm -rf dist *.tsbuildinfo && nest build",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest run",
    "test:e2e": "dotenv -e ../../.env -- vitest run --config vitest.e2e.config.ts",
    "pretest:e2e": "pnpm build",
    "seed:templates": "dotenv -e ../../.env -- tsx scripts/seed-templates.ts",
    "seed:resources": "dotenv -e ../../.env -- tsx scripts/seed-resources.ts",
    "seed:membership": "dotenv -e ../../.env -- pnpm --filter @autix/database run db:init-membership",
    "seed:pricing": "dotenv -e ../../.env -- tsx scripts/seed-pricing.ts",
    "backfill:generation-materials": "dotenv -e ../../.env -- tsx scripts/backfill-generation-materials.ts",
    "fix:api-key": "dotenv -e ../../.env -- tsx scripts/fix-api-key-simple.ts",
    "fix:model": "dotenv -e ../../.env -- tsx scripts/quick-fix-model.ts",
    "update:model-key": "dotenv -e ../../.env -- tsx scripts/update-model-key.ts"
  },
  "dependencies": {
    "@autix/ai-adapters": "workspace:*",
    "@autix/database": "workspace:*",
    "@autix/domain": "workspace:*",
    "@autix/i18n": "workspace:*",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@langchain/anthropic": "^1.3.28",
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.4.5",
    "@langchain/textsplitters": "^1.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "deepagents": "^1.9.0",
    "dotenv": "^17.4.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jose": "^6.0.0",
    "js-yaml": "^4.1.1",
    "langchain": "^1.3.5",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "onnxruntime-node": "1.14.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sharp": "^0.32.6",
    "undici": "^7.28.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^11.0.0",
    "playwright": "^1.61.1",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
