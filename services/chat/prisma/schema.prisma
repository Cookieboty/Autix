generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model artifact_versions {
  id              String    @id @default(cuid())
  artifactId      String
  version         Int
  content         String
  changelog       String?
  sourcetags      String[]
  sourceMessageId String?
  createdAt       DateTime  @default(now())
  artifacts       artifacts @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  messages        messages? @relation(fields: [sourceMessageId], references: [id])

  @@unique([artifactId, version])
  @@index([artifactId, createdAt])
  @@index([artifactId, sourcetags])
}

model artifacts {
  id                String              @id @default(cuid())
  conversationId    String              @unique
  userId            String
  title             String
  type              ArtifactType        @default(MARKDOWN)
  language          String?
  content           String
  currentVersion    Int                 @default(1)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  artifact_versions artifact_versions[]
  conversations     conversations       @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model conversations {
  id        String     @id @default(cuid())
  userId    String
  title     String     @default("New Conversation")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  artifacts artifacts?
  messages  messages[]

  @@index([userId])
}

model document_chunks {
  id         String                 @id @default(cuid())
  documentId String
  content    String
  embedding  Unsupported("vector")?
  chunkIndex Int
  documents  documents              @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model documents {
  id              String            @id @default(cuid())
  userId          String
  filename        String
  mimeType        String
  createdAt       DateTime          @default(now())
  filePath        String?
  size            Int
  storageBucket   String?
  storageKey      String?
  storageRegion   String?
  storageType     String            @default("local")
  storageUrl      String?
  chunkCount      Int               @default(0)
  status          String            @default("pending")
  document_chunks document_chunks[]

  @@index([userId])
}

model messages {
  id                String              @id @default(cuid())
  conversationId    String
  role              MessageRole
  content           String
  createdAt         DateTime            @default(now())
  metadata          Json?
  artifact_versions artifact_versions[]
  conversations     conversations       @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model model_configs {
  id           String          @id @default(cuid())
  name         String          @db.VarChar(100)
  provider     String          @default("openai") @db.VarChar(50)
  model        String          @db.VarChar(100)
  type         ModelType       @default(general)
  priority     Int             @default(0)
  baseUrl      String?         @db.VarChar(200)
  apiKey       String?         @db.VarChar(200)
  metadata     Json?
  isActive     Boolean         @default(true)
  isDefault    Boolean         @default(false)
  visibility   ModelVisibility @default(public)
  createdBy    String?         @db.VarChar(50)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  capabilities String[]        @default(["text"])

  @@index([createdBy])
  @@index([isActive])
  @@index([isDefault])
  @@index([type])
  @@index([visibility])
}

model task_events {
  id        String     @id @default(cuid())
  userId    String     @db.VarChar(255)
  taskType  String     @db.VarChar(100)
  taskId    String     @db.VarChar(255)
  status    TaskStatus
  message   String?
  metadata  Json?
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  readAt    DateTime?  @db.Timestamptz(6)

  @@index([taskType])
  @@index([userId, createdAt])
}

enum ArtifactType {
  MARKDOWN
  CODE
  DOCUMENT
  TABLE
  CHART
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ModelType {
  general
  code
  intent
  embedding
}

enum ModelVisibility {
  public
  private
}

enum TaskStatus {
  pending
  processing
  done
  error
}

model arena_sessions {
  id               String        @id @default(cuid())
  userId           String
  title            String        @default("新对比")
  selectedModelIds String[]      @default([])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  turns            arena_turns[]

  @@index([userId])
}

model arena_turns {
  id          String            @id @default(cuid())
  sessionId   String
  session     arena_sessions    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userMessage String
  images      String[]          @default([])
  createdAt   DateTime          @default(now())
  responses   arena_responses[]

  @@index([sessionId])
}

model arena_responses {
  id               String      @id @default(cuid())
  turnId           String
  turn             arena_turns @relation(fields: [turnId], references: [id], onDelete: Cascade)
  modelConfigId    String
  content          String      @default("")
  images           String[]    @default([])
  durationMs       Int?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  status           String      @default("pending")
  error            String?
  createdAt        DateTime    @default(now())

  @@index([turnId])
}

// ── Template Marketplace ────────────────────────────────────────────────────

model prompt_templates {
  id            String         @id @default(cuid())
  title         String         @db.VarChar(200)
  description   String?
  category      String         @db.VarChar(50)
  prompt        String
  variables     Json
  coverImage    String?
  exampleImages String[]       @default([])
  modelHint     String?        @db.VarChar(100)
  tags          String[]       @default([])
  version       Int            @default(1)

  status        TemplateStatus @default(PENDING)
  rejectReason  String?

  authorId      String
  useCount      Int            @default(0)
  likeCount     Int            @default(0)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  publishedAt   DateTime?

  generations   template_generations[]

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([useCount])
  @@index([publishedAt])
}

model template_generations {
  id              String           @id @default(cuid())
  templateId      String
  template        prompt_templates @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId          String
  modelUsed       String           @db.VarChar(100)
  resolvedPrompt  String
  variables       Json?
  referenceImage  String?
  generatedImages String[]         @default([])
  status          String           @default("pending")
  error           String?
  durationMs      Int?
  createdAt       DateTime         @default(now())

  turns           generation_turns[]

  @@index([templateId])
  @@index([userId])
}

model generation_turns {
  id           String               @id @default(cuid())
  generationId String
  generation   template_generations @relation(fields: [generationId], references: [id], onDelete: Cascade)
  role         MessageRole
  content      String
  images       String[]             @default([])
  createdAt    DateTime             @default(now())

  @@index([generationId])
}

enum TemplateStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

// ── Membership & Points ───────────────────────────────────────────────────

enum PointsRecordType {
  EARN
  CONSUME
}

enum PointsSource {
  MEMBERSHIP
  PACKAGE
  TASK
  INVITATION
  ADMIN_GRANT
}

enum OrderType {
  MEMBERSHIP
  POINTS_PACKAGE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model membership_levels {
  id             String               @id @default(cuid())
  name           String
  level          Int                  @unique
  monthlyPrice   Decimal              @db.Decimal(10, 2)
  pointsPerMonth Int
  features       Json?
  isActive       Boolean              @default(true)
  sort           Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  plans          membership_plans[]
  memberships    user_memberships[]

  @@index([isActive, sort])
}

model membership_plans {
  id             String           @id @default(cuid())
  levelId        String
  level          membership_levels @relation(fields: [levelId], references: [id])
  billingCycle   BillingCycle
  months         Int
  autoRenew      Boolean          @default(false)
  originalPrice  Decimal          @db.Decimal(10, 2)
  price          Decimal          @db.Decimal(10, 2)
  firstTimePrice Decimal?         @db.Decimal(10, 2)
  discountLabel  String?
  firstTimeLabel String?
  points         Int
  isActive       Boolean          @default(true)
  sort           Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([levelId, billingCycle, autoRenew])
  @@index([isActive, sort])
}

model user_memberships {
  id        String           @id @default(cuid())
  userId    String           @unique
  levelId   String
  level     membership_levels @relation(fields: [levelId], references: [id])
  planId    String?
  autoRenew Boolean          @default(false)
  startedAt DateTime         @default(now())
  expiresAt DateTime
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model points_packages {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  points    Int
  isActive  Boolean  @default(true)
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sort])
}

model user_points {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model points_records {
  id        String           @id @default(cuid())
  userId    String
  type      PointsRecordType
  amount    Int
  source    PointsSource
  sourceId  String?
  balance   Int
  remark    String?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([source])
}

model orders {
  id            String      @id @default(cuid())
  userId        String
  orderNo       String      @unique
  orderType     OrderType
  productId     String
  productName   String
  originalPrice Decimal     @db.Decimal(10, 2)
  amount        Decimal     @db.Decimal(10, 2)
  isFirstTime   Boolean     @default(false)
  status        OrderStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([orderNo])
}

model invite_codes {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  records   invite_records[]

  @@index([code])
}

model invite_records {
  id           String   @id @default(cuid())
  inviteCodeId String
  inviterUserId String
  inviteeUserId String
  rewardPoints  Int      @default(0)
  rewarded      Boolean  @default(false)
  createdAt     DateTime @default(now())

  inviteCode invite_codes @relation(fields: [inviteCodeId], references: [id])

  @@unique([inviteeUserId])
  @@index([inviterUserId])
}

model task_point_costs {
  id        String   @id @default(cuid())
  taskType  String   @unique
  name      String
  cost      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
