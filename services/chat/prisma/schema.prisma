generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model artifact_versions {
  id              String    @id @default(cuid())
  artifactId      String
  version         Int
  content         String
  changelog       String?
  sourcetags      String[]
  sourceMessageId String?
  createdAt       DateTime  @default(now())
  artifacts       artifacts @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  messages        messages? @relation(fields: [sourceMessageId], references: [id])

  @@unique([artifactId, version])
  @@index([artifactId, createdAt])
  @@index([artifactId, sourcetags])
}

model artifacts {
  id                String              @id @default(cuid())
  conversationId    String              @unique
  userId            String
  title             String
  type              ArtifactType        @default(MARKDOWN)
  language          String?
  content           String
  currentVersion    Int                 @default(1)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  artifact_versions artifact_versions[]
  conversations     conversations       @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model conversations {
  id        String     @id @default(cuid())
  userId    String
  title     String     @default("New Conversation")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  artifacts artifacts?
  messages  messages[]

  @@index([userId])
}

model document_chunks {
  id         String                 @id @default(cuid())
  documentId String
  content    String
  embedding  Unsupported("vector")?
  chunkIndex Int
  documents  documents              @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model documents {
  id              String            @id @default(cuid())
  userId          String
  filename        String
  mimeType        String
  createdAt       DateTime          @default(now())
  filePath        String?
  size            Int
  storageBucket   String?
  storageKey      String?
  storageRegion   String?
  storageType     String            @default("local")
  storageUrl      String?
  chunkCount      Int               @default(0)
  status          String            @default("pending")
  document_chunks document_chunks[]

  @@index([userId])
}

model messages {
  id                String              @id @default(cuid())
  conversationId    String
  role              MessageRole
  content           String
  createdAt         DateTime            @default(now())
  metadata          Json?
  artifact_versions artifact_versions[]
  conversations     conversations       @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model model_configs {
  id           String          @id @default(cuid())
  name         String          @db.VarChar(100)
  provider     String          @default("openai") @db.VarChar(50)
  model        String          @db.VarChar(100)
  type         ModelType       @default(general)
  priority     Int             @default(0)
  baseUrl      String?         @db.VarChar(200)
  apiKey       String?         @db.VarChar(200)
  metadata     Json?
  isActive     Boolean         @default(true)
  isDefault    Boolean         @default(false)
  visibility   ModelVisibility @default(public)
  createdBy    String?         @db.VarChar(50)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  capabilities String[]        @default(["text"])

  @@index([createdBy])
  @@index([isActive])
  @@index([isDefault])
  @@index([type])
  @@index([visibility])
}

model task_events {
  id        String     @id @default(cuid())
  userId    String     @db.VarChar(255)
  taskType  String     @db.VarChar(100)
  taskId    String     @db.VarChar(255)
  status    TaskStatus
  message   String?
  metadata  Json?
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  readAt    DateTime?  @db.Timestamptz(6)

  @@index([taskType])
  @@index([userId, createdAt])
}

enum ArtifactType {
  MARKDOWN
  CODE
  DOCUMENT
  TABLE
  CHART
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ModelType {
  general
  code
  intent
  embedding
}

enum ModelVisibility {
  public
  private
}

enum TaskStatus {
  pending
  processing
  done
  error
}

model arena_sessions {
  id               String        @id @default(cuid())
  userId           String
  title            String        @default("新对比")
  selectedModelIds String[]      @default([])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  turns            arena_turns[]

  @@index([userId])
}

model arena_turns {
  id          String            @id @default(cuid())
  sessionId   String
  session     arena_sessions    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userMessage String
  images      String[]          @default([])
  createdAt   DateTime          @default(now())
  responses   arena_responses[]

  @@index([sessionId])
}

model arena_responses {
  id               String      @id @default(cuid())
  turnId           String
  turn             arena_turns @relation(fields: [turnId], references: [id], onDelete: Cascade)
  modelConfigId    String
  content          String      @default("")
  images           String[]    @default([])
  durationMs       Int?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  status           String      @default("pending")
  error            String?
  createdAt        DateTime    @default(now())

  @@index([turnId])
}

// ── Template Marketplace ────────────────────────────────────────────────────

model prompt_templates {
  id            String         @id @default(cuid())
  title         String         @db.VarChar(200)
  description   String?
  category      String         @db.VarChar(50)
  prompt        String
  variables     Json
  coverImage    String?
  exampleImages String[]       @default([])
  modelHint     String?        @db.VarChar(100)
  tags          String[]       @default([])
  version       Int            @default(1)

  status        TemplateStatus @default(PENDING)
  rejectReason  String?

  authorId      String
  useCount      Int            @default(0)
  likeCount     Int            @default(0)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  publishedAt   DateTime?

  generations   template_generations[]

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([useCount])
  @@index([publishedAt])
}

model template_generations {
  id              String           @id @default(cuid())
  templateId      String
  template        prompt_templates @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId          String
  modelUsed       String           @db.VarChar(100)
  resolvedPrompt  String
  variables       Json?
  referenceImage  String?
  generatedImages String[]         @default([])
  status          String           @default("pending")
  error           String?
  durationMs      Int?
  createdAt       DateTime         @default(now())

  turns           generation_turns[]

  @@index([templateId])
  @@index([userId])
}

model generation_turns {
  id           String               @id @default(cuid())
  generationId String
  generation   template_generations @relation(fields: [generationId], references: [id], onDelete: Cascade)
  role         MessageRole
  content      String
  images       String[]             @default([])
  createdAt    DateTime             @default(now())

  @@index([generationId])
}

enum TemplateStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}
