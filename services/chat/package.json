{
  "name": "@autix/chat",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run db:generate && dotenv -e ../../.env -- nest start --watch",
    "build": "bun run db:generate && rm -rf dist tsconfig.tsbuildinfo && nest build",
    "start": "dotenv -e ../../.env -- bun run dist/main.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "seed:templates": "dotenv -e ../../.env -- bun run scripts/seed-templates.ts",
    "seed:resources": "dotenv -e ../../.env -- bun run scripts/seed-resources.ts",
    "seed:membership": "dotenv -e ../../.env -- bun run scripts/seed-membership.ts",
    "fix:api-key": "dotenv -e ../../.env -- bun run scripts/fix-api-key-simple.ts",
    "fix:model": "dotenv -e ../../.env -- bun run scripts/quick-fix-model.ts",
    "update:model-key": "dotenv -e ../../.env -- bun run scripts/update-model-key.ts"
  },
  "dependencies": {
    "@autix/contracts": "workspace:*",
    "@autix/i18n": "workspace:*",
    "@autix/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@langchain/anthropic": "^1.3.28",
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.4.5",
    "@langchain/textsplitters": "^1.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@xenova/transformers": "^2.17.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "deepagents": "^1.9.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "langchain": "^1.3.5",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "onnxruntime-node": "1.14.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^11.0.0",
    "prisma": "^7.7.0",
    "typescript": "^5.7.0"
  }
}
