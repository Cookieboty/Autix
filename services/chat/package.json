{
  "name": "@autix/chat",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --ignore dist --exec \"bun run build && bun --watch run dist/main.js\"",
    "build": "rm -rf dist tsconfig.tsbuildinfo && nest build",
    "start": "bun run dist/main.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@autix/contracts": "workspace:*",
    "@autix/types": "workspace:*",
    "@langchain/core": "^1.1.36",
    "@langchain/openai": "^1.3.1",
    "@langchain/textsplitters": "^1.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@xenova/transformers": "^2.17.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.1",
    "js-yaml": "^4.1.1",
    "langchain": "^1.2.37",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "onnxruntime-node": "1.14.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^11.0.0",
    "prisma": "^7.7.0",
    "typescript": "^5.7.0"
  }
}
